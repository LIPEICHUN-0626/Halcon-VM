<Window x:Class="HalconWinFormsDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="HALCON VM 工业视觉平台"
        MinWidth="1120"
        MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="9,3" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="MetricCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="MinWidth" Value="76" />
        </Style>
        <Style x:Key="PanelHeader" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="10,8" />
        </Style>
        <DrawingBrush x:Key="FlowGridBrush" TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute" Viewbox="0,0,24,24" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#F7F9FC" Geometry="M0,0 H24 V24 H0 Z" />
                    <GeometryDrawing Brush="#DDE4EE" Geometry="M23,23 H25 V25 H23 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#E9EEF5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="440" />
            <RowDefinition Height="5" />
            <RowDefinition x:Name="BottomPanelRow" Height="220" MinHeight="90" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Menu Grid.Row="0" Background="#F8FAFC" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1" Padding="4,1">
                    <MenuItem Header="文件">
                        <MenuItem Header="新建配方" Click="NewRecipeButton_Click" />
                        <MenuItem Header="打开配方" Click="LoadRecipeButton_Click" />
                        <MenuItem Header="保存配方" Click="SaveRecipeButton_Click" />
                        <Separator />
                        <MenuItem Header="打开图片" Click="OpenImageButton_Click" />
                        <MenuItem Header="批量图片" Click="OpenFolderButton_Click" />
                    </MenuItem>
                    <MenuItem Header="运行">
                        <MenuItem Header="运行全流程" Click="RunOnceButton_Click" />
                        <MenuItem Header="运行当前" Click="RunCurrentToolButton_Click" />
                        <MenuItem Header="运行到此" Click="RunToHereButton_Click" />
                        <MenuItem Header="从此运行" Click="RunFromHereButton_Click" />
                        <Separator />
                        <MenuItem Header="连续运行" Click="RunContinuousButton_Click" />
                        <MenuItem Header="暂停 / 继续" Click="PauseRunButton_Click" />
                        <MenuItem Header="停止" Click="StopRunButton_Click" />
                    </MenuItem>
                    <MenuItem Header="视图">
                        <MenuItem Header="流程适应窗口" Click="FitFlowButton_Click" />
                        <MenuItem Header="图像适应窗口" Click="FitImageButton_Click" />
                        <MenuItem Header="项目自检" Click="DiagnosticsButton_Click" />
                    </MenuItem>
                    <MenuItem Header="帮助">
                        <MenuItem Header="关于 HALCON VM" Click="AboutMenuItem_Click" />
                    </MenuItem>
                </Menu>
                <DockPanel Grid.Row="1" LastChildFill="True" Margin="12,6,12,4">
                    <UniformGrid DockPanel.Dock="Right" Columns="4" Width="330" VerticalAlignment="Center">
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="OK" Foreground="#64748B" /><TextBlock x:Name="MetricOkText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#15803D" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="NG" Foreground="#64748B" /><TextBlock x:Name="MetricNgText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#B91C1C" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="良率" Foreground="#64748B" /><TextBlock x:Name="MetricYieldText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#1D4ED8" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="节拍" Foreground="#64748B" /><TextBlock x:Name="MetricCycleText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#111827" /></StackPanel>
                        </Border>
                    </UniformGrid>
                    <StackPanel>
                        <TextBlock Text="HALCON VM 工业视觉平台" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock x:Name="RecipeNameText" Text="配方：未加载" Foreground="#64748B" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <WrapPanel Grid.Row="2" Margin="8,0,8,6" VerticalAlignment="Center">
                    <Button x:Name="NewRecipeButton" Content="新建" Click="NewRecipeButton_Click" />
                    <Button x:Name="LoadRecipeButton" Content="打开配方" Click="LoadRecipeButton_Click" />
                    <Button x:Name="SaveRecipeButton" Content="保存" Click="SaveRecipeButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="OpenImageButton" Content="打开图片" Click="OpenImageButton_Click" />
                    <Button x:Name="OpenFolderButton" Content="批量图片" Click="OpenFolderButton_Click" />
                    <Button x:Name="PreviousImageButton" Content="上一张" Click="PreviousImageButton_Click" />
                    <Button x:Name="NextImageButton" Content="下一张" Click="NextImageButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="RunOnceButton" Content="▶ 单次运行" FontWeight="Bold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                    <Button x:Name="RunContinuousButton" Content="连续运行" Click="RunContinuousButton_Click" />
                    <Button x:Name="PauseRunButton" Content="Ⅱ 暂停" Click="PauseRunButton_Click" />
                    <Button x:Name="StopRunButton" Content="■ 停止" Click="StopRunButton_Click" />
                    <TextBlock Text="间隔(ms)" Margin="8,0,2,0" VerticalAlignment="Center" Foreground="#475569" />
                    <TextBox x:Name="ContinuousIntervalTextBox" Width="62" Text="500" ToolTip="连续运行相邻周期的间隔，50-60000 ms" />
                    <TextBlock Text="超时(ms)" Margin="6,0,2,0" VerticalAlignment="Center" Foreground="#475569" />
                    <TextBox x:Name="FlowTimeoutTextBox" Width="68" Text="0" ToolTip="单次流程总超时；0 表示关闭" />
                    <CheckBox x:Name="StopOnNgCheckBox" Content="遇 NG 停止" Margin="7,0" VerticalAlignment="Center" />
                    <Button x:Name="PlayButton" Content="图片播放" Click="PlayButton_Click" />
                    <Button x:Name="StopPlayButton" Content="停止播放" Click="StopPlayButton_Click" />
                    <Button x:Name="ClearOverlayButton" Content="清除叠加" Click="ClearOverlayButton_Click" />
                    <Button x:Name="SaveScreenshotButton" Content="截图" Click="SaveScreenshotButton_Click" />
                    <Button x:Name="DiagnosticsButton" Content="自检" Click="DiagnosticsButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="250" />
                <RowDefinition Height="5" />
                <RowDefinition Height="2*" MinHeight="210" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="520" MinWidth="390" />
            </Grid.ColumnDefinitions>

            <!-- VM-style toolbox -->
            <Border Grid.Column="0" Grid.RowSpan="3" Background="#182235" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="工具箱" Style="{StaticResource PanelHeader}" />
                    <TextBox x:Name="ToolSearchTextBox" Grid.Row="1" Margin="8,0,8,8" TextChanged="ToolSearchTextBox_TextChanged" ToolTip="搜索工具名称、分类或说明" />
                    <ListBox x:Name="ToolCatalogList" Grid.Row="2" Margin="6,0" Background="#111827" BorderThickness="0" Foreground="#E2E8F0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ToolCatalogList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="1" BorderBrush="#334155" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Category}" Foreground="#38BDF8" FontSize="11" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="AddToolButton" Grid.Row="3" Content="＋ 添加到流程" Margin="8" FontWeight="SemiBold" Click="AddToolButton_Click" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Visible execution order -->
            <Border Grid.Column="2" Grid.RowSpan="3" Background="{StaticResource FlowGridBrush}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#263449" Padding="8,5">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Left" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1,1,1,0" CornerRadius="3,3,0,0" Padding="12,5" Margin="0,3,8,0">
                                <TextBlock Text="流程1" Foreground="#0F172A" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock DockPanel.Dock="Right" Text="确定性顺序执行" Foreground="#93C5FD" VerticalAlignment="Center" Margin="10,0" />
                            <StackPanel>
                                <TextBlock Text="流程编辑器" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock x:Name="RunModeText" Text="模式：手动调试" Foreground="#A7F3D0" FontSize="11" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#EEF2F7" Padding="6,4" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <WrapPanel>
                                <Button Content="▶ 当前" MinWidth="66" Click="RunCurrentToolButton_Click" />
                                <Button Content="运行到此" MinWidth="72" Click="RunToHereButton_Click" />
                                <Button Content="从此运行" MinWidth="72" Click="RunFromHereButton_Click" />
                                <Button Content="▶ 全流程" MinWidth="76" FontWeight="SemiBold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                                <Separator Width="6" Opacity="0" />
                                <TextBlock Text="缩放" Margin="4,0" VerticalAlignment="Center" Foreground="#475569" />
                                <Slider x:Name="FlowZoomSlider" Width="100" Minimum="0.65" Maximum="1.35" Value="1" TickFrequency="0.05" ValueChanged="FlowZoomSlider_ValueChanged" VerticalAlignment="Center" />
                                <Button Content="适应" MinWidth="54" Click="FitFlowButton_Click" />
                            </WrapPanel>
                            <DockPanel Grid.Row="1" Margin="3,2,3,0">
                                <TextBlock x:Name="ImageIndexText" DockPanel.Dock="Right" Text="队列：0/0" FontSize="10" Foreground="#64748B" />
                                <TextBlock x:Name="CurrentFileText" Text="当前文件：--" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </DockPanel>
                        </Grid>
                    </Border>
                    <ListBox x:Name="FlowToolList" Grid.Row="2" Margin="4" Padding="18,10" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="FlowToolList_SelectionChanged" MouseDoubleClick="FlowToolList_MouseDoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="配置模块" FontWeight="SemiBold" Click="ConfigureToolButton_Click" />
                                <Separator />
                                <MenuItem Header="运行当前" Click="RunCurrentToolButton_Click" />
                                <MenuItem Header="运行到此" Click="RunToHereButton_Click" />
                                <MenuItem Header="从此运行" Click="RunFromHereButton_Click" />
                                <Separator />
                                <MenuItem Header="运行全流程" Click="RunOnceButton_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.LayoutTransform>
                            <ScaleTransform x:Name="FlowCanvasScaleTransform" ScaleX="1" ScaleY="1" />
                        </ListBox.LayoutTransform>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="22" /></Grid.RowDefinitions>
                                    <Border x:Name="ToolCard" Margin="2" Padding="9" CornerRadius="4" Background="#FFFFFF" BorderBrush="#AAB6C5" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14" Background="#E0F2FE" Margin="0,0,7,0">
                                                <TextBlock Text="{Binding SequenceText}" Foreground="#0369A1" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,7,0" ToolTip="启用/禁用" Checked="FlowToolEnabledCheckBox_Changed" Unchecked="FlowToolEnabledCheckBox_Changed" />
                                            <TextBlock Grid.Column="2" Text="{Binding InstanceName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="3" Background="#E2E8F0" CornerRadius="8" Padding="7,2"><TextBlock Text="{Binding ResultCode}" FontWeight="Bold" Foreground="#475569" /></Border>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding DisplayType}" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding ConfigurationStatus}" FontSize="10" Foreground="#0369A1" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding RunStatus}" FontSize="10" Foreground="#475569" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding ElapsedText}" FontSize="10" Foreground="#64748B" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding ConnectionSummary}" FontSize="10" Foreground="#7C3AED" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" ToolTip="{Binding ConnectionStatus}" />
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" HorizontalAlignment="Center" Width="28">
                                        <Rectangle Width="2" Fill="#64748B" HorizontalAlignment="Center" />
                                        <Polygon Points="9,14 19,14 14,20" Fill="#64748B" VerticalAlignment="Bottom" />
                                    </Grid>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="OK"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#22C55E" /></DataTrigger>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="NG"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#EF4444" /></DataTrigger>
                                    <DataTrigger Binding="{Binding RunStatus}" Value="运行中"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#F59E0B" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"><Setter TargetName="ToolCard" Property="Background" Value="#EFF6FF" /><Setter TargetName="ToolCard" Property="BorderBrush" Value="#2563EB" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="3" Margin="5">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <UniformGrid Columns="5">
                            <Button Content="配置" MinWidth="48" Click="ConfigureToolButton_Click" />
                            <Button Content="上移" MinWidth="48" Click="MoveToolUpButton_Click" />
                            <Button Content="下移" MinWidth="48" Click="MoveToolDownButton_Click" />
                            <Button Content="删除" MinWidth="48" Click="DeleteToolButton_Click" />
                            <Button Content="重命名" MinWidth="48" Click="RenameToolButton_Click" />
                        </UniformGrid>
                        <UniformGrid Grid.Row="1" Columns="3">
                            <Button Content="运行到此" FontWeight="SemiBold" Click="RunToHereButton_Click" />
                            <Button Content="从此运行" FontWeight="SemiBold" Click="RunFromHereButton_Click" />
                            <Button Content="运行全流程" FontWeight="SemiBold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Grid.RowSpan="3" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Right-top HALCON image workspace -->
            <Border Grid.Column="4" Grid.Row="0" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#182235" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="4">
                        <WrapPanel VerticalAlignment="Center">
                            <Button Content="选择" MinWidth="50" Click="SelectImageToolButton_Click" ToolTip="退出绘制，恢复选择模式" />
                            <Button Content="平移" MinWidth="50" Click="PanImageToolButton_Click" ToolTip="按住右键拖动图像" />
                            <Separator Width="5" Opacity="0" />
                            <Button Content="矩形" MinWidth="50" Click="RectangleRoiButton_Click" />
                            <Button Content="圆形" MinWidth="50" Click="CircleRoiButton_Click" />
                            <Button Content="多边形" MinWidth="58" Click="PolygonRoiButton_Click" />
                            <Button Content="✓ 确认" MinWidth="58" FontWeight="SemiBold" Foreground="#34D399" Click="ConfirmRoiButton_Click" />
                            <Button Content="取消" MinWidth="50" Click="CancelRoiDrawingButton_Click" />
                            <Separator Width="5" Opacity="0" />
                            <Button Content="适应" MinWidth="50" Click="FitImageButton_Click" />
                            <Button Content="1:1" MinWidth="50" Click="ImageOriginalSizeButton_Click" />
                            <Button x:Name="ToggleRoiLayerPanelButton" Content="隐藏图层" MinWidth="68" Click="ToggleRoiLayerPanelButton_Click" />
                        </WrapPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="RoiLayerPanelColumn" Width="220" />
                        </Grid.ColumnDefinitions>
                        <wfi:WindowsFormsHost x:Name="HalconHost" Margin="1" />
                        <Border x:Name="RoiLayerPanel" Grid.Column="1" Background="#111827" BorderBrush="#334155" BorderThickness="1,0,0,0" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <DockPanel Margin="2,2,2,6">
                                    <Border DockPanel.Dock="Right" Background="#0F766E" CornerRadius="8" Padding="7,2"><TextBlock x:Name="RoiLayerCountText" Text="0" Foreground="White" FontSize="10" /></Border>
                                    <TextBlock Text="ROI 图层" Foreground="#F8FAFC" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </DockPanel>
                                <ListBox x:Name="RoiLayerList" Grid.Row="1" Background="#111827" BorderThickness="0" Foreground="#E2E8F0" HorizontalContentAlignment="Stretch" SelectionChanged="RoiLayerList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="RoiLayerCard" Background="#182235" BorderBrush="#334155" BorderThickness="1" CornerRadius="3" Padding="6" Margin="1,1,1,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="#164E63" Margin="0,0,6,0"><TextBlock Text="{Binding SequenceText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A5F3FC" FontSize="9" FontWeight="Bold" /></Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ShapeText}" Foreground="#67E8F9" FontSize="10" />
                                                        <TextBlock Text="{Binding BindingSummary}" Foreground="#A78BFA" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <CheckBox IsChecked="{Binding IsVisible}" ToolTip="显示/隐藏" Content="眼" Foreground="#CBD5E1" Checked="RoiLayerVisibilityCheckBox_Changed" Unchecked="RoiLayerVisibilityCheckBox_Changed" />
                                                        <CheckBox IsChecked="{Binding IsEnabled}" ToolTip="参与/退出运行" Content="用" Foreground="#CBD5E1" Checked="RoiLayerEnabledCheckBox_Changed" Unchecked="RoiLayerEnabledCheckBox_Changed" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False"><Setter TargetName="RoiLayerCard" Property="Opacity" Value="0.55" /></DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="2" Text="选中图层后在右侧“图像/ROI”绑定工具" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" Margin="2,6,2,2" />
                            </Grid>
                        </Border>
                    </Grid>
                    <Border Grid.Row="2" Background="#182235" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="7,4">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Name="OverlayStatusText" Foreground="#CBD5E1" Text="图像区：拖拽图片或打开文件夹开始" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="HeaderStatusText" Grid.Column="1" Foreground="#A7F3D0" Text="就绪" Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="4" Grid.Row="1" Height="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Selected tool inspector and retained device/project entries -->
