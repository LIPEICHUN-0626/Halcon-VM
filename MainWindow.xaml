<Window x:Class="HalconWinFormsDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="HALCON VM 工业视觉平台"
        MinWidth="1120"
        MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="9,3" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="MetricCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="MinWidth" Value="76" />
        </Style>
        <Style x:Key="PanelHeader" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="10,8" />
        </Style>
        <DrawingBrush x:Key="FlowGridBrush" TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute" Viewbox="0,0,24,24" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#F7F9FC" Geometry="M0,0 H24 V24 H0 Z" />
                    <GeometryDrawing Brush="#DDE4EE" Geometry="M23,23 H25 V25 H23 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#E9EEF5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="440" />
            <RowDefinition Height="5" />
            <RowDefinition x:Name="BottomPanelRow" Height="220" MinHeight="90" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Menu Grid.Row="0" Background="#F8FAFC" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1" Padding="4,1">
                    <MenuItem Header="文件">
                        <MenuItem Header="新建方案" Click="NewRecipeButton_Click" />
                        <MenuItem Header="打开方案" Click="LoadRecipeButton_Click" />
                        <MenuItem Header="保存方案" Click="SaveRecipeButton_Click" />
                        <MenuItem Header="方案另存为" Click="SaveRecipeAsButton_Click" />
                        <Separator />
                        <MenuItem Header="打开图片" Click="OpenImageButton_Click" />
                        <MenuItem Header="批量图片" Click="OpenFolderButton_Click" />
                    </MenuItem>
                    <MenuItem Header="运行">
                        <MenuItem Header="运行全流程" Click="RunOnceButton_Click" />
                        <MenuItem Header="运行当前" Click="RunCurrentToolButton_Click" />
                        <MenuItem Header="运行到此" Click="RunToHereButton_Click" />
                        <MenuItem Header="从此运行" Click="RunFromHereButton_Click" />
                        <Separator />
                        <MenuItem Header="连续运行" Click="RunContinuousButton_Click" />
                        <MenuItem Header="暂停 / 继续" Click="PauseRunButton_Click" />
                        <MenuItem Header="停止" Click="StopRunButton_Click" />
                    </MenuItem>
                    <MenuItem Header="视图">
                        <MenuItem Header="流程适应窗口" Click="FitFlowButton_Click" />
                        <MenuItem Header="图像适应窗口" Click="FitImageButton_Click" />
                        <MenuItem Header="项目自检" Click="DiagnosticsButton_Click" />
                    </MenuItem>
                    <MenuItem Header="帮助">
                        <MenuItem Header="关于 HALCON VM" Click="AboutMenuItem_Click" />
                    </MenuItem>
                </Menu>
                <DockPanel Grid.Row="1" LastChildFill="True" Margin="12,6,12,4">
                    <UniformGrid DockPanel.Dock="Right" Columns="4" Width="330" VerticalAlignment="Center">
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="OK" Foreground="#64748B" /><TextBlock x:Name="MetricOkText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#15803D" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="NG" Foreground="#64748B" /><TextBlock x:Name="MetricNgText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#B91C1C" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="良率" Foreground="#64748B" /><TextBlock x:Name="MetricYieldText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#1D4ED8" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="节拍" Foreground="#64748B" /><TextBlock x:Name="MetricCycleText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#111827" /></StackPanel>
                        </Border>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock Text="HALCON VM 工业视觉平台" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock x:Name="RecipeNameText" Text="方案：未加载" Foreground="#64748B" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border x:Name="RecipeStateBadge" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="10" Padding="9,3" Margin="12,4,0,4" VerticalAlignment="Center">
                            <TextBlock x:Name="RecipeStateBadgeText" Text="新方案" Foreground="#92400E" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </DockPanel>
                <WrapPanel Grid.Row="2" Margin="8,0,8,6" VerticalAlignment="Center">
                    <Button x:Name="NewRecipeButton" Content="新建" Click="NewRecipeButton_Click" />
                    <Button x:Name="LoadRecipeButton" Content="打开方案" Click="LoadRecipeButton_Click" />
                    <Button x:Name="SaveRecipeButton" Content="保存" Click="SaveRecipeButton_Click" />
                    <Button x:Name="SaveRecipeAsButton" Content="另存为" Click="SaveRecipeAsButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="OpenImageButton" Content="打开图片" Click="OpenImageButton_Click" />
                    <Button x:Name="OpenFolderButton" Content="批量图片" Click="OpenFolderButton_Click" />
                    <Button x:Name="PreviousImageButton" Content="上一张" Click="PreviousImageButton_Click" />
                    <Button x:Name="NextImageButton" Content="下一张" Click="NextImageButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="RunOnceButton" Content="▶ 单次运行" FontWeight="Bold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                    <Button x:Name="RunContinuousButton" Content="连续运行" Click="RunContinuousButton_Click" />
                    <Button x:Name="PauseRunButton" Content="Ⅱ 暂停" Click="PauseRunButton_Click" />
                    <Button x:Name="StopRunButton" Content="■ 停止" Click="StopRunButton_Click" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="间隔(ms)" Margin="8,0,2,0" VerticalAlignment="Center" Foreground="#475569" />
                        <TextBox x:Name="ContinuousIntervalTextBox" Width="62" Text="500" ToolTip="连续运行相邻周期的间隔，50-60000 ms" />
                        <TextBlock Text="超时(ms)" Margin="6,0,2,0" VerticalAlignment="Center" Foreground="#475569" />
                        <TextBox x:Name="FlowTimeoutTextBox" Width="68" Text="0" ToolTip="单次流程总超时；0 表示关闭" />
                        <CheckBox x:Name="StopOnNgCheckBox" Content="遇 NG 停止" Margin="7,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button x:Name="PlayButton" Content="图片播放" Click="PlayButton_Click" />
                    <Button x:Name="StopPlayButton" Content="停止播放" Click="StopPlayButton_Click" />
                    <Button x:Name="ClearOverlayButton" Content="清除叠加" Click="ClearOverlayButton_Click" />
                    <Button x:Name="SaveScreenshotButton" Content="截图" Click="SaveScreenshotButton_Click" />
                    <Button x:Name="DiagnosticsButton" Content="自检" Click="DiagnosticsButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid x:Name="MainWorkspaceGrid" Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ImageWorkspaceRow" Height="3*" MinHeight="280" />
                <RowDefinition Height="5" />
                <RowDefinition x:Name="RightConfigurationRow" Height="2*" MinHeight="210" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="520" MinWidth="390" />
            </Grid.ColumnDefinitions>

            <!-- VM-style toolbox -->
            <Border Grid.Column="0" Grid.RowSpan="3" Background="#182235" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="工具箱" Style="{StaticResource PanelHeader}" />
                    <TextBox x:Name="ToolSearchTextBox" Grid.Row="1" Margin="8,0,8,8" TextChanged="ToolSearchTextBox_TextChanged" ToolTip="搜索工具名称、分类或说明" />
                    <UniformGrid Grid.Row="2" Columns="3" Margin="6,0,6,6">
                        <Button x:Name="ToolCatalogAllButton" Content="全部" MinWidth="0" MinHeight="25" Padding="3,1" Click="ToolCatalogModeButton_Click" Tag="All" />
                        <Button x:Name="ToolCatalogFavoriteButton" Content="★ 收藏" MinWidth="0" MinHeight="25" Padding="3,1" Click="ToolCatalogModeButton_Click" Tag="Favorite" />
                        <Button x:Name="ToolCatalogRecentButton" Content="最近" MinWidth="0" MinHeight="25" Padding="3,1" Click="ToolCatalogModeButton_Click" Tag="Recent" />
                    </UniformGrid>
                    <Grid Grid.Row="3" Margin="6,0">
                        <ListBox x:Name="ToolCatalogList" Background="#111827" BorderThickness="0" Foreground="#E2E8F0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ToolCatalogList_MouseDoubleClick" PreviewMouseLeftButtonDown="ToolCatalogList_PreviewMouseLeftButtonDown" PreviewMouseMove="ToolCatalogList_PreviewMouseMove">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True" Background="#111827" Foreground="#E2E8F0">
                                                            <Expander.Header>
                                                                <DockPanel Margin="3,5,3,3">
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ItemCount, StringFormat={}({0})}" Foreground="#64748B" FontSize="10" />
                                                                    <TextBlock Text="{Binding Name}" Foreground="#38BDF8" FontWeight="SemiBold" />
                                                                </DockPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="1" BorderBrush="#334155" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Category}" Foreground="#38BDF8" FontSize="11" />
                                                <TextBlock Text="{Binding RecentText}" Foreground="#A7F3D0" FontSize="10" Margin="8,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                                            <TextBlock Text="拖入流程可指定线性插入位置" Foreground="#64748B" FontSize="10" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{Binding FavoriteGlyph}" ToolTip="{Binding FavoriteHint}" Tag="{Binding}" MinWidth="28" Width="28" MinHeight="26" Height="26" Padding="0" Margin="4,0,0,0" VerticalAlignment="Top" Foreground="#FBBF24" Background="Transparent" BorderBrush="#475569" Click="ToolCatalogFavoriteButton_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="ToolCatalogEmptyText" Text="当前筛选没有工具。可切换“全部”或清空搜索。" Visibility="Collapsed" Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Margin="18" IsHitTestVisible="False" />
                    </Grid>
                    <TextBlock x:Name="ToolCatalogStatusText" Grid.Row="4" Text="按分类显示 · 双击或拖入流程" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" Margin="9,5,9,0" />
                    <Button x:Name="AddToolButton" Grid.Row="5" Content="＋ 追加到流程末尾" Margin="8" FontWeight="SemiBold" Click="AddToolButton_Click" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Visible execution order -->
            <Border Grid.Column="2" Grid.RowSpan="3" Background="{StaticResource FlowGridBrush}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#263449" Padding="8,5">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Left" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1,1,1,0" CornerRadius="3,3,0,0" Padding="12,5" Margin="0,3,8,0">
                                <TextBlock Text="流程1" Foreground="#0F172A" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock DockPanel.Dock="Right" Text="确定性顺序执行" Foreground="#93C5FD" VerticalAlignment="Center" Margin="10,0" />
                            <StackPanel>
                                <TextBlock Text="流程编辑器" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock x:Name="RunModeText" Text="模式：手动调试" Foreground="#A7F3D0" FontSize="11" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#EEF2F7" Padding="6,4" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <WrapPanel>
                                <Button Content="▶ 当前" MinWidth="66" Click="RunCurrentToolButton_Click" />
                                <Button Content="运行到此" MinWidth="72" Click="RunToHereButton_Click" />
                                <Button Content="从此运行" MinWidth="72" Click="RunFromHereButton_Click" />
                                <Button Content="▶ 全流程" MinWidth="76" FontWeight="SemiBold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                                <Separator Width="6" Opacity="0" />
                                <TextBlock Text="缩放" Margin="4,0" VerticalAlignment="Center" Foreground="#475569" />
                                <Slider x:Name="FlowZoomSlider" Width="100" Minimum="0.65" Maximum="1.35" Value="1" TickFrequency="0.05" ValueChanged="FlowZoomSlider_ValueChanged" VerticalAlignment="Center" />
                                <Button Content="适应" MinWidth="54" Click="FitFlowButton_Click" />
                            </WrapPanel>
                            <DockPanel Grid.Row="1" Margin="3,2,3,0">
                                <TextBlock x:Name="ImageIndexText" DockPanel.Dock="Right" Text="队列：0/0" FontSize="10" Foreground="#64748B" />
                                <TextBlock x:Name="CurrentFileText" Text="当前文件：--" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            </DockPanel>
                        </Grid>
                    </Border>
                    <ListBox x:Name="FlowToolList" Grid.Row="2" Margin="4" Padding="18,10" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="FlowToolList_SelectionChanged" MouseDoubleClick="FlowToolList_MouseDoubleClick" AllowDrop="True" PreviewDragOver="FlowToolList_PreviewDragOver" DragLeave="FlowToolList_DragLeave" Drop="FlowToolList_Drop">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="配置模块" FontWeight="SemiBold" Click="ConfigureToolButton_Click" />
                                <Separator />
                                <MenuItem Header="运行当前" Click="RunCurrentToolButton_Click" />
                                <MenuItem Header="运行到此" Click="RunToHereButton_Click" />
                                <MenuItem Header="从此运行" Click="RunFromHereButton_Click" />
                                <Separator />
                                <MenuItem Header="运行全流程" Click="RunOnceButton_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.LayoutTransform>
                            <ScaleTransform x:Name="FlowCanvasScaleTransform" ScaleX="1" ScaleY="1" />
                        </ListBox.LayoutTransform>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="22" /></Grid.RowDefinitions>
                                    <Border x:Name="ToolCard" Margin="2" Padding="9" CornerRadius="4" Background="#FFFFFF" BorderBrush="#AAB6C5" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14" Background="#E0F2FE" Margin="0,0,7,0">
                                                <TextBlock Text="{Binding SequenceText}" Foreground="#0369A1" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,7,0" ToolTip="启用/禁用" Checked="FlowToolEnabledCheckBox_Changed" Unchecked="FlowToolEnabledCheckBox_Changed" />
                                            <TextBlock Grid.Column="2" Text="{Binding InstanceName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="3" Background="#E2E8F0" CornerRadius="8" Padding="7,2"><TextBlock Text="{Binding ResultCode}" FontWeight="Bold" Foreground="#475569" /></Border>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding DisplayType}" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding ConfigurationStatus}" FontSize="10" Foreground="#0369A1" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding RunStatus}" FontSize="10" Foreground="#475569" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding ElapsedText}" FontSize="10" Foreground="#64748B" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding ConnectionSummary}" FontSize="10" Foreground="#7C3AED" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" ToolTip="{Binding ConnectionStatus}" />
                                            <TextBlock Grid.Row="4" Grid.ColumnSpan="4" Text="{Binding DependencySummary}" FontSize="10" Foreground="#475569" Margin="0,5,0,2" TextTrimming="CharacterEllipsis" />
                                            <ItemsControl Grid.Row="5" Grid.ColumnSpan="4" ItemsSource="{Binding FlowInputPorts}" Margin="0,1,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="InputPortChip" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="6,3" Margin="0,0,5,4" ToolTip="{Binding StatusText}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="10" FontWeight="SemiBold"><Run Text="IN  " Foreground="#7C3AED" /><Run Text="{Binding PortText, Mode=OneWay}" /></TextBlock>
                                                                <TextBlock Text="{Binding EndpointText}" FontSize="9" Foreground="#475569" MaxWidth="250" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="Ready"><Setter TargetName="InputPortChip" Property="Background" Value="#ECFDF5" /><Setter TargetName="InputPortChip" Property="BorderBrush" Value="#10B981" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="Waiting"><Setter TargetName="InputPortChip" Property="Background" Value="#FFFBEB" /><Setter TargetName="InputPortChip" Property="BorderBrush" Value="#F59E0B" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="Missing"><Setter TargetName="InputPortChip" Property="Background" Value="#FEF2F2" /><Setter TargetName="InputPortChip" Property="BorderBrush" Value="#EF4444" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="Error"><Setter TargetName="InputPortChip" Property="Background" Value="#FEF2F2" /><Setter TargetName="InputPortChip" Property="BorderBrush" Value="#DC2626" /></DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl Grid.Row="6" Grid.ColumnSpan="4" ItemsSource="{Binding FlowOutputPorts}">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="OutputPortChip" Background="#F0FDFA" BorderBrush="#5EEAD4" BorderThickness="1" CornerRadius="3" Padding="6,3" Margin="0,0,5,2" ToolTip="{Binding StatusText}">
                                                            <StackPanel>
                                                                <TextBlock FontSize="10" FontWeight="SemiBold"><Run Text="OUT  " Foreground="#0F766E" /><Run Text="{Binding PortText, Mode=OneWay}" /></TextBlock>
                                                                <TextBlock Text="{Binding EndpointText}" FontSize="9" Foreground="#475569" MaxWidth="250" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="Waiting"><Setter TargetName="OutputPortChip" Property="Background" Value="#F8FAFC" /><Setter TargetName="OutputPortChip" Property="BorderBrush" Value="#CBD5E1" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding StateKey}" Value="NG"><Setter TargetName="OutputPortChip" Property="Background" Value="#FEF2F2" /><Setter TargetName="OutputPortChip" Property="BorderBrush" Value="#EF4444" /></DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" HorizontalAlignment="Center" Width="28">
                                        <Rectangle Width="2" Fill="#64748B" HorizontalAlignment="Center" />
                                        <Polygon Points="9,14 19,14 14,20" Fill="#64748B" VerticalAlignment="Bottom" />
                                    </Grid>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="OK"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#22C55E" /></DataTrigger>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="NG"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#EF4444" /></DataTrigger>
                                    <DataTrigger Binding="{Binding RunStatus}" Value="运行中"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#F59E0B" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                    <DataTrigger Binding="{Binding DependencyState}" Value="Upstream"><Setter TargetName="ToolCard" Property="Background" Value="#F5F3FF" /><Setter TargetName="ToolCard" Property="BorderBrush" Value="#8B5CF6" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                    <DataTrigger Binding="{Binding DependencyState}" Value="Downstream"><Setter TargetName="ToolCard" Property="Background" Value="#F0FDFA" /><Setter TargetName="ToolCard" Property="BorderBrush" Value="#14B8A6" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"><Setter TargetName="ToolCard" Property="Background" Value="#EFF6FF" /><Setter TargetName="ToolCard" Property="BorderBrush" Value="#2563EB" /><Setter TargetName="ToolCard" Property="BorderThickness" Value="2" /></DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border x:Name="FlowDropHintBorder" Grid.Row="2" Panel.ZIndex="10" Visibility="Collapsed" IsHitTestVisible="False" VerticalAlignment="Top" HorizontalAlignment="Center" Background="#E60F766E" BorderBrush="#5EEAD4" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="12">
                        <TextBlock x:Name="FlowDropHintText" Text="插入位置：流程末尾" Foreground="White" FontWeight="SemiBold" />
                    </Border>
                    <Grid Grid.Row="3" Margin="5">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <UniformGrid Columns="5">
                            <Button Content="配置" MinWidth="48" Click="ConfigureToolButton_Click" />
                            <Button Content="上移" MinWidth="48" Click="MoveToolUpButton_Click" />
                            <Button Content="下移" MinWidth="48" Click="MoveToolDownButton_Click" />
                            <Button Content="删除" MinWidth="48" Click="DeleteToolButton_Click" />
                            <Button Content="重命名" MinWidth="48" Click="RenameToolButton_Click" />
                        </UniformGrid>
                        <UniformGrid Grid.Row="1" Columns="3">
                            <Button Content="运行到此" FontWeight="SemiBold" Click="RunToHereButton_Click" />
                            <Button Content="从此运行" FontWeight="SemiBold" Click="RunFromHereButton_Click" />
                            <Button Content="运行全流程" FontWeight="SemiBold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Grid.RowSpan="3" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Right-top HALCON image workspace -->
            <Border x:Name="ImageWorkspacePanel" Grid.Column="4" Grid.Row="0" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#182235" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="4">
                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <Button x:Name="ImageWorkspaceExpandButton" Content="⛶ 放大图像" MinWidth="82" FontWeight="SemiBold" Foreground="#67E8F9" Click="ImageWorkspaceExpandButton_Click" ToolTip="临时把图像区扩展到主工作区；恢复后保留原流程与配置布局" />
                                <Button Content="选择" MinWidth="50" Click="SelectImageToolButton_Click" ToolTip="退出绘制，恢复选择模式" />
                                <Button Content="平移" MinWidth="50" Click="PanImageToolButton_Click" ToolTip="按住右键拖动图像" />
                                <Separator Width="5" Opacity="0" />
                                <Button Content="矩形" MinWidth="50" Click="RectangleRoiButton_Click" />
                                <Button Content="圆形" MinWidth="50" Click="CircleRoiButton_Click" />
                                 <Button Content="旋转矩形" MinWidth="68" Click="RotatedRectangleRoiButton_Click" ToolTip="从中心向主轴拖动创建；选中后可旋转并调整宽高" />
                                 <Button Content="多边形" MinWidth="58" Click="PolygonRoiButton_Click" />
                                 <Button Content="✓ 确认" MinWidth="58" FontWeight="SemiBold" Foreground="#34D399" Click="ConfirmRoiButton_Click" />
                                 <Button Content="取消" MinWidth="50" Click="CancelRoiDrawingButton_Click" />
                                 <Button Content="复制ROI" MinWidth="62" Click="CopySelectedRoiButton_Click" ToolTip="复制选中 ROI 并保留工具绑定" />
                                 <Button Content="锁定" MinWidth="50" Click="ToggleSelectedRoiLockButton_Click" ToolTip="锁定或解锁选中 ROI" />
                                <Separator Width="5" Opacity="0" />
                                <Button Content="适应" MinWidth="50" Click="FitImageButton_Click" />
                                <Button Content="1:1" MinWidth="50" Click="ImageOriginalSizeButton_Click" />
                                <Button x:Name="ToggleRoiLayerPanelButton" Content="隐藏图层" MinWidth="68" Click="ToggleRoiLayerPanelButton_Click" />
                                <CheckBox x:Name="ShowRoiOverlayCheckBox" Content="ROI叠加" IsChecked="True" Foreground="#67E8F9" VerticalAlignment="Center" Margin="8,0,2,0" Checked="ImageOverlayVisibility_Changed" Unchecked="ImageOverlayVisibility_Changed" ToolTip="只控制 ROI 图层显示，不删除图层或绑定" />
                                <CheckBox x:Name="ShowResultOverlayCheckBox" Content="结果叠加" IsChecked="True" Foreground="#FDE68A" VerticalAlignment="Center" Margin="6,0,2,0" Checked="ImageOverlayVisibility_Changed" Unchecked="ImageOverlayVisibility_Changed" ToolTip="只控制算法结果显示，不释放输出快照" />
                            </WrapPanel>
                            <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="3" Margin="2,4,2,0" Padding="7,5">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="图像上下文" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <ComboBox x:Name="ImageContextComboBox" Grid.Column="1" DisplayMemberPath="DisplayText" SelectedValuePath="Key" SelectionChanged="ImageContextComboBox_SelectionChanged" MinHeight="26" />
                                    <TextBlock x:Name="ImageContextDetailText" Grid.Column="2" Text="--" Foreground="#67E8F9" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                                    <TextBlock x:Name="ImageContextSourceText" Grid.Row="1" Grid.ColumnSpan="3" Text="来源：全局输入" Foreground="#E2E8F0" FontSize="10" VerticalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="RoiLayerPanelColumn" Width="220" />
                        </Grid.ColumnDefinitions>
                        <wfi:WindowsFormsHost x:Name="HalconHost" Margin="1" />
                        <Border x:Name="ImageEmptyStateBorder" Grid.Column="0" Visibility="Collapsed" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" Margin="1" Padding="24">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                                <TextBlock Text="暂无可显示图像" Foreground="#E2E8F0" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                                <TextBlock x:Name="ImageEmptyStateText" Text="请选择全局输入，或先运行具有 Image 输出的上游模块。" Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="RoiLayerPanel" Grid.Column="1" Background="#111827" BorderBrush="#334155" BorderThickness="1,0,0,0" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <DockPanel Margin="2,2,2,6">
                                    <Border DockPanel.Dock="Right" Background="#0F766E" CornerRadius="8" Padding="7,2"><TextBlock x:Name="RoiLayerCountText" Text="0" Foreground="White" FontSize="10" /></Border>
                                    <TextBlock Text="ROI 图层" Foreground="#F8FAFC" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </DockPanel>
                                <ListBox x:Name="RoiLayerList" Grid.Row="1" Background="#111827" BorderThickness="0" Foreground="#E2E8F0" HorizontalContentAlignment="Stretch" SelectionChanged="RoiLayerList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="RoiLayerCard" Background="#182235" BorderBrush="#334155" BorderThickness="1" CornerRadius="3" Padding="6" Margin="1,1,1,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="#164E63" Margin="0,0,6,0"><TextBlock Text="{Binding SequenceText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A5F3FC" FontSize="9" FontWeight="Bold" /></Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ShapeText}" Foreground="#67E8F9" FontSize="10" />
                                                        <TextBlock Text="{Binding BindingSummary}" Foreground="#A78BFA" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock x:Name="RoiContextResultText" Text="{Binding ContextResultText}" Foreground="#94A3B8" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                         <CheckBox IsChecked="{Binding IsVisible}" ToolTip="显示/隐藏" Content="眼" Foreground="#CBD5E1" Checked="RoiLayerVisibilityCheckBox_Changed" Unchecked="RoiLayerVisibilityCheckBox_Changed" />
                                                         <CheckBox IsChecked="{Binding IsEnabled}" ToolTip="参与/退出运行" Content="用" Foreground="#CBD5E1" Checked="RoiLayerEnabledCheckBox_Changed" Unchecked="RoiLayerEnabledCheckBox_Changed" />
                                                         <CheckBox IsChecked="{Binding IsLocked, Mode=OneWay}" ToolTip="锁定几何与删除" Content="锁" Foreground="#FDE68A" Checked="RoiLayerLockCheckBox_Changed" Unchecked="RoiLayerLockCheckBox_Changed" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False"><Setter TargetName="RoiLayerCard" Property="Opacity" Value="0.55" /></DataTrigger>
                                                <DataTrigger Binding="{Binding ContextResultCode}" Value="OK"><Setter TargetName="RoiLayerCard" Property="BorderBrush" Value="#22C55E" /><Setter TargetName="RoiContextResultText" Property="Foreground" Value="#86EFAC" /></DataTrigger>
                                                <DataTrigger Binding="{Binding ContextResultCode}" Value="NG"><Setter TargetName="RoiLayerCard" Property="BorderBrush" Value="#EF4444" /><Setter TargetName="RoiContextResultText" Property="Foreground" Value="#FCA5A5" /></DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="2" Text="选择模式：绿色控制点编辑几何，橙色圆点旋转；锁定可防止误改" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap" Margin="2,6,2,2" />
                            </Grid>
                        </Border>
                    </Grid>
                    <Border Grid.Row="2" Background="#182235" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="7,4">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock x:Name="OverlayStatusText" Foreground="#FDE68A" Text="结果：无可用叠加" TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                            <TextBlock x:Name="RoiOverlayLegendText" Grid.Column="1" Foreground="#67E8F9" Text="ROI：0 个" Margin="12,0,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                            <TextBlock x:Name="ImagePixelStatusText" Grid.Column="2" Foreground="#FDE68A" Text="像素：--" Margin="12,0,0,0" />
                            <TextBlock x:Name="HeaderStatusText" Grid.Column="3" Foreground="#A7F3D0" Text="就绪" Margin="12,0,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="4" Grid.Row="1" Height="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Selected tool inspector and retained device/project entries -->
            <TabControl Grid.Column="4" Grid.Row="2" x:Name="RightTabs" SelectionChanged="RightTabs_SelectionChanged">
                <TabItem x:Name="ModuleResultTab" Header="模块结果">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <Border Background="#263449" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="FlowRunStatusText" Text="流程待命" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock x:Name="FlowRunRangeText" Text="范围：--" Foreground="#BFDBFE" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#0F766E" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                                        <TextBlock x:Name="FlowRunResultText" Text="--" Foreground="White" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                            <GroupBox Header="本次流程运行">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Text="总耗时" /><TextBlock x:Name="FlowRunElapsedText" Grid.Column="1" Text="--" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Text="停止原因" /><TextBlock x:Name="FlowStopReasonText" Grid.Row="1" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="2" Text="当前工具" /><TextBlock x:Name="FlowCurrentToolText" Grid.Row="2" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="3" Text="安全边界" /><TextBlock Grid.Row="3" Grid.Column="1" Text="暂停、停止和超时在工具步骤之间生效" Foreground="#64748B" TextWrapping="Wrap" />
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="选中模块结果">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Text="模块" /><TextBlock x:Name="SelectedResultToolText" Grid.Column="1" Text="--" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="1" Text="状态" /><TextBlock x:Name="SelectedResultStatusText" Grid.Row="1" Grid.Column="1" Text="--" />
                                    <TextBlock Grid.Row="2" Text="输出" /><TextBlock x:Name="SelectedResultOutputText" Grid.Row="2" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="3" Text="错误" /><TextBlock x:Name="SelectedResultErrorText" Grid.Row="3" Grid.Column="1" Text="--" Foreground="#B91C1C" TextWrapping="Wrap" />
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="逐 ROI 结果">
                                <DataGrid x:Name="SelectedRoiResultsDataGrid" Height="145" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ROI" Binding="{Binding RoiName}" Width="90" />
                                        <DataGridTextColumn Header="判定" Binding="{Binding ResultCode}" Width="55" />
                                        <DataGridTextColumn Header="数值" Binding="{Binding ValueText}" Width="110" />
                                        <DataGridTextColumn Header="耗时" Binding="{Binding ElapsedText}" Width="65" />
                                        <DataGridTextColumn Header="说明" Binding="{Binding DisplayMessage}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                            <UniformGrid Columns="4">
                                <Button Content="当前" Click="RunCurrentToolButton_Click" />
                                <Button Content="到此" Click="RunToHereButton_Click" />
                                <Button Content="从此" Click="RunFromHereButton_Click" />
                                <Button Content="全流程" Foreground="#0F766E" FontWeight="SemiBold" Click="RunOnceButton_Click" />
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="DockConfigurationTab" Header="模块配置" ToolTip="常驻模块配置工作台">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <Border Background="#263449" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="DockModuleTitleText" Text="请选择流程模块" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock x:Name="DockModuleTypeText" Text="右侧常驻配置，不打开主要参数弹窗" Foreground="#BFDBFE" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#0F766E" CornerRadius="10" Padding="9,3" VerticalAlignment="Center">
                                    <TextBlock x:Name="DockDraftStateText" Text="无草稿" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                                <DockPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button x:Name="DockRevertButton" Content="撤销草稿" MinWidth="68" MinHeight="25" Click="DockRevertButton_Click" />
                                        <Button x:Name="DockApplyButton" Content="应用" MinWidth="62" MinHeight="25" Foreground="#34D399" FontWeight="SemiBold" Click="DockApplyButton_Click" />
                                    </StackPanel>
                                    <Button x:Name="DockTrialRunButton" DockPanel.Dock="Left" Content="▶ 试运行" MinWidth="72" MinHeight="25" Click="DockTrialRunButton_Click" />
                                    <TextBlock x:Name="DockFooterText" Text="选择模块开始配置" VerticalAlignment="Center" Foreground="#CBD5E1" Margin="8,0" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Grid>
                        </Border>
                        <TabControl x:Name="DockConfigurationTabs" Grid.Row="1" Margin="6">
                            <TabItem Header="基本参数">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="9">
                                        <GroupBox Header="实例">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="实例名称" VerticalAlignment="Center" />
                                                <TextBox x:Name="DockInstanceNameTextBox" Grid.Column="1" TextChanged="DockDraftValue_Changed" />
                                            </Grid>
                                        </GroupBox>
                                        <TextBlock x:Name="DockEmptyText" Text="从中央流程选择一个模块后即可配置。" Foreground="#64748B" TextWrapping="Wrap" Margin="4,6" />
                                        <StackPanel x:Name="DockImageSourcePanel" Visibility="Collapsed">
                                            <GroupBox Header="本地图像源">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /><ColumnDefinition Width="76" /></Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                    <TextBlock Text="图像文件" VerticalAlignment="Center" />
                                                    <TextBox x:Name="DockLocalImagePathTextBox" Grid.Column="1" TextChanged="DockDraftValue_Changed" />
                                                    <Button Grid.Column="2" Content="选择" Click="DockBrowseLocalImageButton_Click" />
                                                    <TextBlock Grid.Row="1" Text="图像 SN" VerticalAlignment="Center" />
                                                    <TextBox x:Name="DockLocalImageSerialTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" TextChanged="DockDraftValue_Changed" />
                                                </Grid>
                                            </GroupBox>
                                        </StackPanel>
                                         <StackPanel x:Name="DockImageChannelPanel" Visibility="Collapsed">
                                            <GroupBox Header="HALCON 图像通道">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                    <TextBlock Text="处理模式" VerticalAlignment="Center" />
                                                    <ComboBox x:Name="DockImageChannelModeComboBox" Grid.Column="1" DisplayMemberPath="DisplayText" SelectedValuePath="Key" SelectionChanged="DockDraftValue_Changed" />
                                                    <TextBlock Grid.Row="1" Text="通道序号" VerticalAlignment="Center" />
                                                    <TextBox x:Name="DockImageChannelIndexTextBox" Grid.Row="1" Grid.Column="1" TextChanged="DockDraftValue_Changed" ToolTip="仅提取指定通道时生效，从 1 开始" />
                                                </Grid>
                                            </GroupBox>
                                         </StackPanel>
                                         <StackPanel x:Name="DockImageFilterPanel" Visibility="Collapsed">
                                             <GroupBox Header="HALCON 图像滤波">
                                                 <Grid>
                                                     <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /><ColumnDefinition Width="68" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                     <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                     <TextBlock Text="滤波模式" VerticalAlignment="Center" />
                                                     <ComboBox x:Name="DockImageFilterModeComboBox" Grid.Column="1" Grid.ColumnSpan="3" DisplayMemberPath="DisplayText" SelectedValuePath="Key" SelectionChanged="DockDraftValue_Changed" />
                                                     <TextBlock Grid.Row="1" Text="模板宽" VerticalAlignment="Center" />
                                                     <TextBox x:Name="DockImageFilterWidthTextBox" Grid.Row="1" Grid.Column="1" TextChanged="DockDraftValue_Changed" ToolTip="均值滤波：3 到 255 的奇数" />
                                                     <TextBlock Grid.Row="1" Grid.Column="2" Text="模板高" VerticalAlignment="Center" />
                                                     <TextBox x:Name="DockImageFilterHeightTextBox" Grid.Row="1" Grid.Column="3" TextChanged="DockDraftValue_Changed" ToolTip="均值滤波：3 到 255 的奇数" />
                                                     <TextBlock Grid.Row="2" Text="中值半径" VerticalAlignment="Center" />
                                                     <TextBox x:Name="DockImageFilterRadiusTextBox" Grid.Row="2" Grid.Column="1" TextChanged="DockDraftValue_Changed" ToolTip="中值滤波：1 到 100" />
                                                     <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Text="均值使用宽×高；中值使用圆形半径" Foreground="#64748B" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                 </Grid>
                                             </GroupBox>
                                         </StackPanel>
                                         <StackPanel x:Name="DockImageThresholdPanel" Visibility="Collapsed">
                                             <GroupBox Header="HALCON 阈值分割">
                                                 <Grid>
                                                     <Grid.ColumnDefinitions><ColumnDefinition Width="88" /><ColumnDefinition Width="*" /><ColumnDefinition Width="68" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                     <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                     <TextBlock Text="灰度下限" VerticalAlignment="Center" />
                                                     <TextBox x:Name="DockImageThresholdMinTextBox" Grid.Column="1" TextChanged="DockDraftValue_Changed" ToolTip="0 到 255，且不大于灰度上限" />
                                                     <TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" />
                                                     <TextBox x:Name="DockImageThresholdMaxTextBox" Grid.Column="3" TextChanged="DockDraftValue_Changed" ToolTip="0 到 255，且不小于灰度下限" />
