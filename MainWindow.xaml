                                    <TextBlock x:Name="RoiStatusText" Text="ROI：未设置" TextWrapping="Wrap" Margin="4" />
                                    <TextBlock Text="每次确认都会新增一个图层，并自动绑定到当前选中的视觉工具。滚轮缩放、右键平移。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="选中 ROI 图层">
                                <StackPanel>
                                    <TextBlock x:Name="RoiSelectedLayerText" Text="未选择 ROI 图层" FontWeight="SemiBold" Foreground="#334155" Margin="4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="名称" VerticalAlignment="Center" />
                                        <TextBox x:Name="SelectedRoiLayerNameTextBox" Grid.Column="1" IsEnabled="False" LostFocus="SelectedRoiLayerNameTextBox_LostFocus" />
                                    </Grid>
                                    <UniformGrid Columns="2">
                                        <Button x:Name="ClearRoiButton" Content="删除选中" Click="ClearRoiButton_Click" />
                                        <Button x:Name="ClearAllRoiLayersButton" Content="清空全部" Click="ClearAllRoiLayersButton_Click" />
                                    </UniformGrid>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="绑定到当前工具">
                                <StackPanel>
                                    <TextBlock x:Name="RoiBindingToolText" Text="请先选择流程中的视觉工具" FontWeight="SemiBold" Foreground="#475569" TextWrapping="Wrap" Margin="4" />
                                    <ItemsControl x:Name="RoiBindingItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsBound}" VerticalAlignment="Center" Margin="2,0,8,0" Checked="RoiBindingCheckBox_Changed" Unchecked="RoiBindingCheckBox_Changed" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding ShapeText}" Foreground="#64748B" FontSize="10" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding StateText}" Foreground="#0F766E" FontSize="10" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="RoiBindingsStatusText" Text="绑定后，运行时会合并所有已启用 ROI。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />
                                    <Button Content="运行当前工具验证 ROI" FontWeight="SemiBold" Foreground="#0F766E" Click="RunCurrentToolButton_Click" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="模板快捷入口">
                                <StackPanel>
                                    <Button Content="选择 Shape 工具并打开参数" Click="SelectShapeToolButton_Click" />
                                    <TextBlock Text="主要模板参数保留在 Shape Inspector；搜索区域由该工具绑定的 ROI 图层提供。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="通讯" ToolTip="设备/通讯">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="TCP 通讯">
                                <StackPanel>
                                    <UniformGrid Columns="2">
                                        <RadioButton x:Name="TcpClientModeRadio" Content="TCP客户端" IsChecked="True" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                        <RadioButton x:Name="TcpServerModeRadio" Content="TCP服务端" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                    </UniformGrid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" /><ColumnDefinition Width="82" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock x:Name="TcpIpLabel" Text="远端IP" VerticalAlignment="Center" /><TextBox x:Name="TcpIpTextBox" Grid.Column="1" Text="127.0.0.1" />
                                        <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" /><TextBox x:Name="TcpPortTextBox" Grid.Column="3" Text="9000" />
                                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="4">
                                            <Button x:Name="TcpConnectButton" Content="连接" Click="TcpConnectButton_Click" /><Button x:Name="TcpDisconnectButton" Content="断开" Click="TcpDisconnectButton_Click" />
                                            <Button x:Name="TcpStartServerButton" Content="启动监听" Click="TcpStartServerButton_Click" /><Button x:Name="TcpStopServerButton" Content="停止监听" Click="TcpStopServerButton_Click" />
                                        </WrapPanel>
                                    </Grid>
                                    <WrapPanel>
                                        <TextBlock Text="编码" VerticalAlignment="Center" Margin="4" />
                                        <ComboBox x:Name="TcpEncodingCombo" Width="92" SelectedIndex="0"><ComboBoxItem Content="UTF-8" /><ComboBoxItem Content="ASCII" /><ComboBoxItem Content="GBK" /></ComboBox>
                                        <CheckBox x:Name="TcpAppendNewLineCheckBox" Content="追加换行" IsChecked="True" Margin="8,4" />
                                        <CheckBox x:Name="AutoSendMatchResultCheckBox" Content="自动发送结果" IsChecked="True" Margin="8,4" />
                                    </WrapPanel>
                                    <TextBlock x:Name="TcpStatusText" Text="未连接，发送不可用" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="手动测试">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="110" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBox x:Name="TcpSendTextBox" Text="Hello" AcceptsReturn="True" Height="65" VerticalScrollBarVisibility="Auto" />
                                    <Button x:Name="TcpSendButton" Grid.Column="1" Content="发送文本" FontWeight="Bold" Click="TcpSendButton_Click" />
                                    <Button x:Name="SendLastMatchButton" Grid.Row="1" Grid.ColumnSpan="2" Content="发送最新流程结果" FontWeight="Bold" Click="SendLastMatchButton_Click" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="ProjectDiagnosticsTab" Header="工程" ToolTip="工程/诊断">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="当前配方">
                                <StackPanel>
                                    <TextBox x:Name="RecipeNameEditTextBox" Text="DefaultRecipe" />
                                    <TextBlock x:Name="RecipePathText" Text="路径：--" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                    <WrapPanel><Button Content="打开配方目录" Click="OpenRecipeDirectoryButton_Click" /><Button Content="打开日志目录" Click="OpenLogDirectoryButton_Click" /></WrapPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="启动自检">
                                <DataGrid x:Name="DiagnosticsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Height="260">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="项目" Binding="{Binding Name}" Width="125" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="55" />
                                        <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <GridSplitter Grid.Row="2" Height="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

        <TabControl Grid.Row="3" x:Name="BottomTabs" Margin="8,0,8,5">
            <TabItem Header="结果记录">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <WrapPanel Margin="4">
                        <Button x:Name="ReviewResultButton" Content="回看结果" Click="ReviewResultButton_Click" /><Button x:Name="ExportCsvButton" Content="导出CSV" Click="ExportCsvButton_Click" /><Button x:Name="ExportXlsxButton" Content="导出XLSX" Click="ExportXlsxButton_Click" /><Button x:Name="ClearResultsButton" Content="清空记录" Click="ClearResultsButton_Click" />
                    </WrapPanel>
                    <DataGrid x:Name="ResultsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="48" /><DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="100" /><DataGridTextColumn Header="类型" Binding="{Binding InspectionType}" Width="145" /><DataGridTextColumn Header="判定" Binding="{Binding ResultCode}" Width="65" /><DataGridTextColumn Header="分数/数量" Binding="{Binding Score, StringFormat=F3}" Width="82" /><DataGridTextColumn Header="ROI" Binding="{Binding RoiType}" Width="75" /><DataGridTextColumn Header="图像" Binding="{Binding ImageSource}" Width="180" /><DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="运行日志">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <WrapPanel Margin="4"><Button x:Name="ClearLogButton" Content="清空日志" Click="ClearLogButton_Click" /><Button x:Name="OpenLogDirectoryButton2" Content="打开日志目录" Click="OpenLogDirectoryButton_Click" /></WrapPanel>
                    <TextBox x:Name="BottomLogTextBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="报警"><TextBox x:Name="AlarmTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" /></TabItem>
            <TabItem Header="通讯记录"><TextBox x:Name="TcpHistoryTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" /></TabItem>
        </TabControl>

        <StatusBar Grid.Row="4" Background="#FFFFFF" BorderBrush="#D6DCE5" BorderThickness="0,1,0,0">
            <StatusBarItem><TextBlock x:Name="ModeStatusText" Text="模式：手动调试" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="FlowRuntimeStatusBarText" Text="流程：待命" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="ImageStatusText" Text="图像：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="ZoomStatusText" Text="缩放：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="MouseStatusText" Text="坐标：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="RoiStatusBarText" Text="ROI：未设置" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="TemplateStatusBarText" Text="模板：未训练" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="TcpStatusBarText" Text="TCP：未连接" /></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
