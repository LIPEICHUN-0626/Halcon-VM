<Window x:Class="HalconWinFormsDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="HALCON VM 工业视觉平台"
        MinWidth="1120"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="9,3" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="MetricCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="MinWidth" Value="76" />
        </Style>
        <Style x:Key="PanelHeader" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="10,8" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#E9EEF5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="440" />
            <RowDefinition Height="5" />
            <RowDefinition x:Name="BottomPanelRow" Height="220" MinHeight="90" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="10,7">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="2,0,2,5">
                    <UniformGrid DockPanel.Dock="Right" Columns="4" Width="330" VerticalAlignment="Center">
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="OK" Foreground="#64748B" /><TextBlock x:Name="MetricOkText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#15803D" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="NG" Foreground="#64748B" /><TextBlock x:Name="MetricNgText" Text="0" FontSize="17" FontWeight="Bold" Foreground="#B91C1C" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="良率" Foreground="#64748B" /><TextBlock x:Name="MetricYieldText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#1D4ED8" /></StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel><TextBlock Text="节拍" Foreground="#64748B" /><TextBlock x:Name="MetricCycleText" Text="--" FontSize="17" FontWeight="Bold" Foreground="#111827" /></StackPanel>
                        </Border>
                    </UniformGrid>
                    <StackPanel>
                        <TextBlock Text="HALCON VM 工业视觉平台" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock x:Name="RecipeNameText" Text="配方：未加载" Foreground="#64748B" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                    <Button x:Name="NewRecipeButton" Content="新建" Click="NewRecipeButton_Click" />
                    <Button x:Name="LoadRecipeButton" Content="打开配方" Click="LoadRecipeButton_Click" />
                    <Button x:Name="SaveRecipeButton" Content="保存" Click="SaveRecipeButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="OpenImageButton" Content="打开图片" Click="OpenImageButton_Click" />
                    <Button x:Name="OpenFolderButton" Content="批量图片" Click="OpenFolderButton_Click" />
                    <Button x:Name="PreviousImageButton" Content="上一张" Click="PreviousImageButton_Click" />
                    <Button x:Name="NextImageButton" Content="下一张" Click="NextImageButton_Click" />
                    <Separator Width="7" Opacity="0" />
                    <Button x:Name="RunOnceButton" Content="▶ 单次运行" FontWeight="Bold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                    <Button x:Name="RunContinuousButton" Content="连续运行" Click="RunContinuousButton_Click" />
                    <Button x:Name="StopRunButton" Content="■ 停止" Click="StopRunButton_Click" />
                    <Button x:Name="PlayButton" Content="图片播放" Click="PlayButton_Click" />
                    <Button x:Name="StopPlayButton" Content="停止播放" Click="StopPlayButton_Click" />
                    <Button x:Name="ClearOverlayButton" Content="清除叠加" Click="ClearOverlayButton_Click" />
                    <Button x:Name="SaveScreenshotButton" Content="截图" Click="SaveScreenshotButton_Click" />
                    <Button x:Name="DiagnosticsButton" Content="自检" Click="DiagnosticsButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="170" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="250" MinWidth="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="340" MinWidth="310" />
            </Grid.ColumnDefinitions>

            <!-- VM-style toolbox -->
            <Border Grid.Column="0" Background="#182235" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="工具箱" Style="{StaticResource PanelHeader}" />
                    <TextBox x:Name="ToolSearchTextBox" Grid.Row="1" Margin="8,0,8,8" TextChanged="ToolSearchTextBox_TextChanged" ToolTip="搜索工具名称、分类或说明" />
                    <ListBox x:Name="ToolCatalogList" Grid.Row="2" Margin="6,0" Background="#111827" BorderThickness="0" Foreground="#E2E8F0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ToolCatalogList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="1" BorderBrush="#334155" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Category}" Foreground="#38BDF8" FontSize="11" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="AddToolButton" Grid.Row="3" Content="＋ 添加到流程" Margin="8" FontWeight="SemiBold" Click="AddToolButton_Click" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Visible execution order -->
            <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#263449" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="流程工具" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock x:Name="RunModeText" Text="模式：手动调试" Foreground="#A7F3D0" FontSize="11" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="顺序执行" Foreground="#93C5FD" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Background="#EEF2F7" Padding="8,5" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="ImageIndexText" Text="队列：0/0" FontSize="11" />
                            <TextBlock x:Name="CurrentFileText" Text="当前文件：--" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="FlowToolList" Grid.Row="2" Margin="4" Background="#F8FAFC" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="FlowToolList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ToolCard" Margin="2" Padding="7" CornerRadius="3" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <Border Width="25" Height="25" CornerRadius="13" Background="#E0F2FE" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding SequenceText}" Foreground="#0369A1" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="启用/禁用" Checked="FlowToolEnabledCheckBox_Changed" Unchecked="FlowToolEnabledCheckBox_Changed" />
                                        <TextBlock Grid.Column="2" Text="{Binding InstanceName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding ResultCode}" FontWeight="Bold" Foreground="#475569" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding DisplayType}" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding ConfigurationStatus}" FontSize="10" Foreground="#0369A1" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding RunStatus}" FontSize="10" Foreground="#475569" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding ElapsedText}" FontSize="10" Foreground="#64748B" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding ConnectionSummary}" FontSize="10" Foreground="#7C3AED" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" ToolTip="{Binding ConnectionStatus}" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="OK"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#22C55E" /></DataTrigger>
                                    <DataTrigger Binding="{Binding ResultCode}" Value="NG"><Setter TargetName="ToolCard" Property="BorderBrush" Value="#EF4444" /></DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="3" Margin="5">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <UniformGrid Columns="4">
                            <Button Content="上移" MinWidth="48" Click="MoveToolUpButton_Click" />
                            <Button Content="下移" MinWidth="48" Click="MoveToolDownButton_Click" />
                            <Button Content="删除" MinWidth="48" Click="DeleteToolButton_Click" />
                            <Button Content="重命名" MinWidth="48" Click="RenameToolButton_Click" />
                        </UniformGrid>
                        <UniformGrid Grid.Row="1" Columns="2">
                            <Button Content="运行当前" FontWeight="SemiBold" Click="RunCurrentToolButton_Click" />
                            <Button Content="运行全流程" FontWeight="SemiBold" Foreground="#0F766E" Click="RunOnceButton_Click" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Central HALCON image workspace -->
            <Border Grid.Column="4" Background="#0B1220" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <wfi:WindowsFormsHost x:Name="HalconHost" Margin="1" />
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#C0111827" CornerRadius="3" Padding="8,4" Margin="9">
                        <TextBlock x:Name="OverlayStatusText" Foreground="#E5E7EB" Text="图像区：拖拽图片或打开文件夹开始" />
                    </Border>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#C0111827" CornerRadius="3" Padding="8,4" Margin="9">
                        <TextBlock x:Name="HeaderStatusText" Foreground="#E5E7EB" Text="就绪" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="5" Width="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

            <!-- Selected tool inspector and retained device/project entries -->
            <TabControl Grid.Column="6" x:Name="RightTabs" SelectionChanged="RightTabs_SelectionChanged">
                <TabItem Header="参数" ToolTip="参数 Inspector">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <Border Background="#263449" CornerRadius="3" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="InspectorToolTitleText" Text="请选择流程工具" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock x:Name="InspectorToolTypeText" Text="从左侧工具箱添加，或在流程中选择实例" Foreground="#CBD5E1" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <GroupBox Header="实例">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Text="名称" VerticalAlignment="Center" />
                                    <TextBox x:Name="ToolInstanceNameTextBox" Grid.Column="1" LostFocus="ToolInstanceNameTextBox_LostFocus" />
                                    <TextBlock Grid.Row="1" Text="状态" VerticalAlignment="Center" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox x:Name="SelectedToolEnabledCheckBox" Content="启用" Margin="4" Checked="SelectedToolEnabledCheckBox_Changed" Unchecked="SelectedToolEnabledCheckBox_Changed" />
                                        <TextBlock x:Name="SelectedToolStatusText" Text="--" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#475569" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <TextBlock x:Name="InspectorEmptyText" Text="选中工具后在此配置主要参数。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />

                            <StackPanel x:Name="ShapeInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="Shape Model 模板匹配">
                                    <StackPanel>
                                        <Button x:Name="TemplateSettingsButton" Content="训练/编辑模板" FontWeight="Bold" Click="TemplateSettingsButton_Click" />
                                        <WrapPanel>
                                            <Button x:Name="SaveTemplateButton" Content="保存模板" Click="SaveTemplateButton_Click" />
                                            <Button x:Name="LoadTemplateButton" Content="加载模板" Click="LoadTemplateButton_Click" />
                                            <Button x:Name="RunMatchButton" Content="独立运行" Click="RunMatchButton_Click" />
                                        </WrapPanel>
                                        <CheckBox x:Name="ShowResultFrameCheckBox" Content="显示匹配外框和中心" IsChecked="True" Margin="4" Checked="OverlayOptionChanged" Unchecked="OverlayOptionChanged" />
                                        <TextBlock x:Name="TemplateStatusText" Text="模板：未训练" TextWrapping="Wrap" Margin="4" />
                                        <TextBlock x:Name="MatchResultText" Text="结果：--" TextWrapping="Wrap" Margin="4" />
                                        <TextBlock x:Name="LastMessageText" Text="最新外发结果：--" TextWrapping="Wrap" Margin="4" Foreground="#475569" />
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel x:Name="BlobInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="Blob 参数">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Text="灰度下限" VerticalAlignment="Center" /><TextBox x:Name="BlobMinGrayTextBox" Grid.Column="1" Text="80" />
                                        <TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" /><TextBox x:Name="BlobMaxGrayTextBox" Grid.Column="3" Text="255" />
                                        <TextBlock Grid.Row="1" Text="最小面积" VerticalAlignment="Center" /><TextBox x:Name="BlobMinAreaTextBox" Grid.Row="1" Grid.Column="1" Text="50" />
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel x:Name="GrayInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="灰度统计参数">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="灰度下限" VerticalAlignment="Center" /><TextBox x:Name="GrayMinTextBox" Grid.Column="1" Text="0" />
                                        <TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" /><TextBox x:Name="GrayMaxTextBox" Grid.Column="3" Text="255" />
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel x:Name="EdgeInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="边缘测量参数">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="边缘阈值" VerticalAlignment="Center" /><TextBox x:Name="EdgeThresholdTextBox" Grid.Column="1" Text="30" />
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel x:Name="HDevInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="HDevelop 扩展">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /><ColumnDefinition Width="82" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Text="过程名" VerticalAlignment="Center" /><TextBox x:Name="HDevProcedureTextBox" Grid.Column="1" Grid.ColumnSpan="2" Text="RunInspection" />
                                        <TextBlock Grid.Row="1" Text="程序" VerticalAlignment="Center" /><TextBox x:Name="HDevPathTextBox" Grid.Row="1" Grid.Column="1" /><Button x:Name="BrowseHDevButton" Grid.Row="1" Grid.Column="2" Content="选择文件" Click="BrowseHDevButton_Click" />
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel x:Name="NumericJudgeInspectorPanel" Visibility="Collapsed">
                                <GroupBox Header="上游数值订阅">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Text="上游工具" VerticalAlignment="Center" />
                                        <ComboBox x:Name="NumericSourceToolComboBox" Grid.Column="1" DisplayMemberPath="DisplayText" SelectedValuePath="ToolId" SelectionChanged="NumericSourceToolComboBox_SelectionChanged" />
                                        <TextBlock Grid.Row="1" Text="数值端口" VerticalAlignment="Center" />
                                        <ComboBox x:Name="NumericSourcePortComboBox" Grid.Row="1" Grid.Column="1" DisplayMemberPath="DisplayText" SelectedValuePath="PortName" SelectionChanged="NumericSourcePortComboBox_SelectionChanged" />
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="判定规则">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="82" /><ColumnDefinition Width="*" /><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock Text="比较方式" VerticalAlignment="Center" />
                                        <ComboBox x:Name="NumericOperatorComboBox" Grid.Column="1" Grid.ColumnSpan="3" DisplayMemberPath="DisplayText" SelectedValuePath="Key" SelectionChanged="NumericOperatorComboBox_SelectionChanged" />
                                        <TextBlock Grid.Row="1" Text="下限/目标" VerticalAlignment="Center" />
                                        <TextBox x:Name="NumericLowerLimitTextBox" Grid.Row="1" Grid.Column="1" Text="0" LostFocus="NumericJudgeParameter_LostFocus" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="上限" VerticalAlignment="Center" />
                                        <TextBox x:Name="NumericUpperLimitTextBox" Grid.Row="1" Grid.Column="3" Text="100" LostFocus="NumericJudgeParameter_LostFocus" />
                                        <TextBlock Grid.Row="2" Text="相等容差" VerticalAlignment="Center" />
                                        <TextBox x:Name="NumericToleranceTextBox" Grid.Row="2" Grid.Column="1" Text="0.001" LostFocus="NumericJudgeParameter_LostFocus" />
                                    </Grid>
                                </GroupBox>
                                <TextBlock x:Name="NumericConfigValidationText" Text="请选择上游工具和端口。" TextWrapping="Wrap" Margin="4,0,4,6" Foreground="#B91C1C" />
                                <UniformGrid Columns="2">
                                    <Button Content="查看 I/O 端口" Click="OpenIoPanelButton_Click" />
                                    <Button Content="独立运行判定" FontWeight="SemiBold" Foreground="#0F766E" Click="NumericJudgeRunButton_Click" />
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel Visibility="Collapsed">
                                <CheckBox x:Name="EnableShapeToolCheckBox" /><CheckBox x:Name="EnableBlobToolCheckBox" /><CheckBox x:Name="EnableGrayToolCheckBox" /><CheckBox x:Name="EnableEdgeToolCheckBox" /><CheckBox x:Name="EnableHDevToolCheckBox" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="I/O" ToolTip="输入/输出">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <Border Background="#263449" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="IoToolTitleText" Text="未选择流程工具" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock x:Name="IoConnectionStatusText" Text="请在流程区选择工具实例。" Foreground="#C4B5FD" TextWrapping="Wrap" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <Button x:Name="IoOpenParametersButton" Content="参数" Click="IoOpenParametersButton_Click" />
                                <Button x:Name="IoRunCurrentButton" Content="运行当前" FontWeight="SemiBold" Click="IoRunCurrentButton_Click" />
                                <Button Content="刷新值" Click="IoRefreshButton_Click" />
                            </UniformGrid>

                            <GroupBox Header="输入端口 IN">
                                <ItemsControl x:Name="InputPortsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PortCard" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border x:Name="PortBadge" Width="30" Height="30" CornerRadius="15" Background="#FEE2E2" VerticalAlignment="Top">
                                                        <TextBlock Text="IN" FontSize="9" FontWeight="Bold" Foreground="#B91C1C" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontWeight="SemiBold"><Run Text="{Binding DisplayName}" /><Run Text="  (" /><Run Text="{Binding PortName}" /><Run Text=")" /></TextBlock>
                                                        <TextBlock Text="{Binding Source, StringFormat=来源：{0}}" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding CurrentValue, StringFormat=当前：{0}}" FontSize="10" Foreground="#334155" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border Background="#EDE9FE" CornerRadius="8" Padding="6,2"><TextBlock Text="{Binding DataType}" FontSize="9" Foreground="#6D28D9" /></Border>
                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="#B45309" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter TargetName="PortCard" Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter TargetName="PortBadge" Property="Background" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="输出端口 OUT">
                                <ItemsControl x:Name="OutputPortsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PortCard" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border x:Name="PortBadge" Width="30" Height="30" CornerRadius="15" Background="#E0E7FF" VerticalAlignment="Top">
                                                        <TextBlock Text="OUT" FontSize="8" FontWeight="Bold" Foreground="#4338CA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontWeight="SemiBold"><Run Text="{Binding DisplayName}" /><Run Text="  (" /><Run Text="{Binding PortName}" /><Run Text=")" /></TextBlock>
                                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding CurrentValue, StringFormat=当前：{0}}" FontSize="10" Foreground="#334155" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border Background="#EDE9FE" CornerRadius="8" Padding="6,2"><TextBlock Text="{Binding DataType}" FontSize="9" Foreground="#6D28D9" /></Border>
                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="#475569" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter TargetName="PortCard" Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter TargetName="PortBadge" Property="Background" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="本次运行摘要">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Text="输入" /><TextBlock x:Name="InspectorInputSummaryText" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Text="输出" /><TextBlock x:Name="InspectorOutputSummaryText" Grid.Row="1" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="2" Text="错误" /><TextBlock x:Name="InspectorErrorText" Grid.Row="2" Grid.Column="1" Text="--" TextWrapping="Wrap" Foreground="#B91C1C" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="图像/ROI">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="ROI 工具">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button x:Name="RectangleRoiButton" Content="矩形ROI" Click="RectangleRoiButton_Click" />
                                        <Button x:Name="CircleRoiButton" Content="圆形ROI" Click="CircleRoiButton_Click" />
                                        <Button x:Name="PolygonRoiButton" Content="多边形ROI" Click="PolygonRoiButton_Click" />
                                        <Button x:Name="ConfirmRoiButton" Content="确认ROI" FontWeight="Bold" Click="ConfirmRoiButton_Click" />
                                        <Button x:Name="ClearRoiButton" Content="清除ROI" Click="ClearRoiButton_Click" />
                                        <Button x:Name="FitImageButton" Content="适应窗口" Click="FitImageButton_Click" />
                                    </WrapPanel>
                                    <TextBlock x:Name="RoiStatusText" Text="ROI：未设置" TextWrapping="Wrap" Margin="4" />
                                    <TextBlock Text="左键绘制；滚轮缩放；右键平移；双击适应。多边形左键加点，双击结束。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="模板快捷入口">
                                <StackPanel>
                                    <Button Content="选择 Shape 工具并打开参数" Click="SelectShapeToolButton_Click" />
                                    <TextBlock Text="主要模板参数已归入 Shape 工具 Inspector；ROI 编辑保留在图像页。" Foreground="#64748B" TextWrapping="Wrap" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="通讯" ToolTip="设备/通讯">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="TCP 通讯">
                                <StackPanel>
                                    <UniformGrid Columns="2">
                                        <RadioButton x:Name="TcpClientModeRadio" Content="TCP客户端" IsChecked="True" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                        <RadioButton x:Name="TcpServerModeRadio" Content="TCP服务端" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                    </UniformGrid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" /><ColumnDefinition Width="82" /></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                        <TextBlock x:Name="TcpIpLabel" Text="远端IP" VerticalAlignment="Center" /><TextBox x:Name="TcpIpTextBox" Grid.Column="1" Text="127.0.0.1" />
                                        <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" /><TextBox x:Name="TcpPortTextBox" Grid.Column="3" Text="9000" />
                                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="4">
                                            <Button x:Name="TcpConnectButton" Content="连接" Click="TcpConnectButton_Click" /><Button x:Name="TcpDisconnectButton" Content="断开" Click="TcpDisconnectButton_Click" />
                                            <Button x:Name="TcpStartServerButton" Content="启动监听" Click="TcpStartServerButton_Click" /><Button x:Name="TcpStopServerButton" Content="停止监听" Click="TcpStopServerButton_Click" />
                                        </WrapPanel>
                                    </Grid>
                                    <WrapPanel>
                                        <TextBlock Text="编码" VerticalAlignment="Center" Margin="4" />
                                        <ComboBox x:Name="TcpEncodingCombo" Width="92" SelectedIndex="0"><ComboBoxItem Content="UTF-8" /><ComboBoxItem Content="ASCII" /><ComboBoxItem Content="GBK" /></ComboBox>
                                        <CheckBox x:Name="TcpAppendNewLineCheckBox" Content="追加换行" IsChecked="True" Margin="8,4" />
                                        <CheckBox x:Name="AutoSendMatchResultCheckBox" Content="自动发送结果" IsChecked="True" Margin="8,4" />
                                    </WrapPanel>
                                    <TextBlock x:Name="TcpStatusText" Text="未连接，发送不可用" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="手动测试">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="110" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBox x:Name="TcpSendTextBox" Text="Hello" AcceptsReturn="True" Height="65" VerticalScrollBarVisibility="Auto" />
                                    <Button x:Name="TcpSendButton" Grid.Column="1" Content="发送文本" FontWeight="Bold" Click="TcpSendButton_Click" />
                                    <Button x:Name="SendLastMatchButton" Grid.Row="1" Grid.ColumnSpan="2" Content="发送最新流程结果" FontWeight="Bold" Click="SendLastMatchButton_Click" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="ProjectDiagnosticsTab" Header="工程" ToolTip="工程/诊断">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="当前配方">
                                <StackPanel>
                                    <TextBox x:Name="RecipeNameEditTextBox" Text="DefaultRecipe" />
                                    <TextBlock x:Name="RecipePathText" Text="路径：--" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                    <WrapPanel><Button Content="打开配方目录" Click="OpenRecipeDirectoryButton_Click" /><Button Content="打开日志目录" Click="OpenLogDirectoryButton_Click" /></WrapPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="启动自检">
                                <DataGrid x:Name="DiagnosticsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Height="260">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="项目" Binding="{Binding Name}" Width="125" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="55" />
                                        <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <GridSplitter Grid.Row="2" Height="5" Background="#CBD5E1" HorizontalAlignment="Stretch" />

        <TabControl Grid.Row="3" x:Name="BottomTabs" Margin="8,0,8,5">
            <TabItem Header="结果记录">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <WrapPanel Margin="4">
                        <Button x:Name="ReviewResultButton" Content="回看结果" Click="ReviewResultButton_Click" /><Button x:Name="ExportCsvButton" Content="导出CSV" Click="ExportCsvButton_Click" /><Button x:Name="ExportXlsxButton" Content="导出XLSX" Click="ExportXlsxButton_Click" /><Button x:Name="ClearResultsButton" Content="清空记录" Click="ClearResultsButton_Click" />
                    </WrapPanel>
                    <DataGrid x:Name="ResultsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="48" /><DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="100" /><DataGridTextColumn Header="类型" Binding="{Binding InspectionType}" Width="145" /><DataGridTextColumn Header="判定" Binding="{Binding ResultCode}" Width="65" /><DataGridTextColumn Header="分数/数量" Binding="{Binding Score, StringFormat=F3}" Width="82" /><DataGridTextColumn Header="ROI" Binding="{Binding RoiType}" Width="75" /><DataGridTextColumn Header="图像" Binding="{Binding ImageSource}" Width="180" /><DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="运行日志">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <WrapPanel Margin="4"><Button x:Name="ClearLogButton" Content="清空日志" Click="ClearLogButton_Click" /><Button x:Name="OpenLogDirectoryButton2" Content="打开日志目录" Click="OpenLogDirectoryButton_Click" /></WrapPanel>
                    <TextBox x:Name="BottomLogTextBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="报警"><TextBox x:Name="AlarmTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" /></TabItem>
            <TabItem Header="通讯记录"><TextBox x:Name="TcpHistoryTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" /></TabItem>
        </TabControl>

        <StatusBar Grid.Row="4" Background="#FFFFFF" BorderBrush="#D6DCE5" BorderThickness="0,1,0,0">
            <StatusBarItem><TextBlock x:Name="ModeStatusText" Text="模式：手动调试" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="ImageStatusText" Text="图像：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="ZoomStatusText" Text="缩放：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="MouseStatusText" Text="坐标：--" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="RoiStatusBarText" Text="ROI：未设置" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="TemplateStatusBarText" Text="模板：未训练" /></StatusBarItem><Separator />
            <StatusBarItem><TextBlock x:Name="TcpStatusBarText" Text="TCP：未连接" /></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
