<Window x:Class="HalconWinFormsDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="HALCON Vision Station"
        MinWidth="1280"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="10,3" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="MetricCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="MinWidth" Value="82" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#EEF2F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="420" />
            <RowDefinition Height="5" />
            <RowDefinition x:Name="BottomPanelRow" Height="220" MinHeight="80" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D6DCE5" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="390" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="HALCON Vision Station" FontSize="18" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBlock x:Name="RecipeNameText" Text="配方：未加载" Foreground="#64748B" Margin="0,2,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button x:Name="NewRecipeButton" Content="新建配方" Click="NewRecipeButton_Click" />
                    <Button x:Name="LoadRecipeButton" Content="加载配方" Click="LoadRecipeButton_Click" />
                    <Button x:Name="SaveRecipeButton" Content="保存配方" Click="SaveRecipeButton_Click" />
                    <Separator Width="8" Opacity="0" />
                    <Button x:Name="OpenImageButton" Content="打开图片" Click="OpenImageButton_Click" />
                    <Button x:Name="OpenFolderButton" Content="打开文件夹" Click="OpenFolderButton_Click" />
                    <Button x:Name="PreviousImageButton" Content="上一张" Click="PreviousImageButton_Click" />
                    <Button x:Name="NextImageButton" Content="下一张" Click="NextImageButton_Click" />
                    <Button x:Name="PlayButton" Content="自动播放" Click="PlayButton_Click" />
                    <Button x:Name="StopPlayButton" Content="停止播放" Click="StopPlayButton_Click" />
                    <Separator Width="8" Opacity="0" />
                    <Button x:Name="RunOnceButton" Content="单次运行" FontWeight="Bold" Click="RunOnceButton_Click" />
                    <Button x:Name="RunContinuousButton" Content="连续运行" Click="RunContinuousButton_Click" />
                    <Button x:Name="StopRunButton" Content="停止运行" Click="StopRunButton_Click" />
                    <Button x:Name="ClearOverlayButton" Content="清除叠加" Click="ClearOverlayButton_Click" />
                    <Button x:Name="SaveScreenshotButton" Content="保存截图" Click="SaveScreenshotButton_Click" />
                    <Button x:Name="DiagnosticsButton" Content="自检" Click="DiagnosticsButton_Click" />
                </WrapPanel>

                <UniformGrid Grid.Column="2" Columns="4" VerticalAlignment="Center">
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="OK" Foreground="#64748B" />
                            <TextBlock x:Name="MetricOkText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#15803D" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="NG" Foreground="#64748B" />
                            <TextBlock x:Name="MetricNgText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#B91C1C" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="良率" Foreground="#64748B" />
                            <TextBlock x:Name="MetricYieldText" Text="--" FontSize="18" FontWeight="Bold" Foreground="#1D4ED8" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="节拍" Foreground="#64748B" />
                            <TextBlock x:Name="MetricCycleText" Text="--" FontSize="18" FontWeight="Bold" Foreground="#111827" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="720" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="430" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="10" Background="#0B1220" BorderBrush="#C7D2E0" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <wfi:WindowsFormsHost x:Name="HalconHost" Margin="1" />
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#B30B1220" CornerRadius="4" Padding="8,4" Margin="10">
                        <TextBlock x:Name="OverlayStatusText" Foreground="#E5E7EB" Text="图像区：拖拽图片或打开文件夹开始" />
                    </Border>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#B30B1220" CornerRadius="4" Padding="8,4" Margin="10">
                        <TextBlock x:Name="HeaderStatusText" Foreground="#E5E7EB" Text="就绪" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CBD5E1" />

            <TabControl Grid.Column="2" x:Name="RightTabs" Margin="0,10,10,10" SelectionChanged="RightTabs_SelectionChanged">
                <TabItem Header="运行流程">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="采集队列">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ImageIndexText" Text="队列：0/0" />
                                    <TextBlock x:Name="CurrentFileText" Grid.Row="1" Text="当前文件：--" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <TextBlock x:Name="RunModeText" Grid.Row="2" Text="模式：手动调试" Foreground="#475569" Margin="0,6,0,0" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="工具链">
                                <StackPanel>
                                    <CheckBox x:Name="EnableShapeToolCheckBox" Content="启用 Shape Model 模板匹配" IsChecked="True" Margin="4" Checked="ToolConfigChanged" Unchecked="ToolConfigChanged" />
                                    <CheckBox x:Name="EnableBlobToolCheckBox" Content="启用 Blob 面积筛选" Margin="4" Checked="ToolConfigChanged" Unchecked="ToolConfigChanged" />
                                    <CheckBox x:Name="EnableGrayToolCheckBox" Content="启用灰度统计判定" Margin="4" Checked="ToolConfigChanged" Unchecked="ToolConfigChanged" />
                                    <CheckBox x:Name="EnableEdgeToolCheckBox" Content="启用边缘测量" Margin="4" Checked="ToolConfigChanged" Unchecked="ToolConfigChanged" />
                                    <CheckBox x:Name="EnableHDevToolCheckBox" Content="启用 HDevelop 扩展调用" Margin="4" Checked="ToolConfigChanged" Unchecked="ToolConfigChanged" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Blob 参数">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="灰度下限" VerticalAlignment="Center" />
                                    <TextBox x:Name="BlobMinGrayTextBox" Grid.Column="1" Text="80" />
                                    <TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" />
                                    <TextBox x:Name="BlobMaxGrayTextBox" Grid.Column="3" Text="255" />
                                    <TextBlock Grid.Row="1" Text="最小面积" VerticalAlignment="Center" />
                                    <TextBox x:Name="BlobMinAreaTextBox" Grid.Row="1" Grid.Column="1" Text="50" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="灰度/边缘/HDevelop">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="灰度下限" VerticalAlignment="Center" />
                                    <TextBox x:Name="GrayMinTextBox" Grid.Column="1" Text="0" />
                                    <TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" />
                                    <TextBox x:Name="GrayMaxTextBox" Grid.Column="3" Text="255" />
                                    <TextBlock Grid.Row="1" Text="边缘阈值" VerticalAlignment="Center" />
                                    <TextBox x:Name="EdgeThresholdTextBox" Grid.Row="1" Grid.Column="1" Text="30" />
                                    <TextBlock Grid.Row="2" Text="过程名" VerticalAlignment="Center" />
                                    <TextBox x:Name="HDevProcedureTextBox" Grid.Row="2" Grid.Column="1" Text="RunInspection" />
                                    <Button x:Name="BrowseHDevButton" Grid.Row="2" Grid.Column="2" Content="HDev文件" Click="BrowseHDevButton_Click" />
                                    <TextBox x:Name="HDevPathTextBox" Grid.Row="2" Grid.Column="3" Text="" ToolTip="HDevelop 程序路径" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="ROI/模板">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="ROI 工具">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button x:Name="RectangleRoiButton" Content="矩形ROI" Click="RectangleRoiButton_Click" />
                                        <Button x:Name="CircleRoiButton" Content="圆形ROI" Click="CircleRoiButton_Click" />
                                        <Button x:Name="PolygonRoiButton" Content="多边形ROI" Click="PolygonRoiButton_Click" />
                                        <Button x:Name="ConfirmRoiButton" Content="确认ROI" FontWeight="Bold" Click="ConfirmRoiButton_Click" />
                                        <Button x:Name="ClearRoiButton" Content="清除ROI" Click="ClearRoiButton_Click" />
                                        <Button x:Name="FitImageButton" Content="适应窗口" Click="FitImageButton_Click" />
                                    </WrapPanel>
                                    <TextBlock x:Name="RoiStatusText" Text="ROI：未设置" TextWrapping="Wrap" Margin="4,6,4,0" />
                                    <TextBlock Text="左键绘制 ROI，滚轮缩放，右键拖动平移，双击适应窗口；多边形左键加点，双击或确认结束。" Foreground="#64748B" TextWrapping="Wrap" Margin="4,4,4,0" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="模板匹配">
                                <StackPanel>
                                    <Button x:Name="TemplateSettingsButton" Content="训练/编辑模板" FontWeight="Bold" Click="TemplateSettingsButton_Click" />
                                    <WrapPanel>
                                        <Button x:Name="SaveTemplateButton" Content="保存模板" Click="SaveTemplateButton_Click" />
                                        <Button x:Name="LoadTemplateButton" Content="加载模板" Click="LoadTemplateButton_Click" />
                                        <Button x:Name="RunMatchButton" Content="单独匹配" Click="RunMatchButton_Click" />
                                    </WrapPanel>
                                    <CheckBox x:Name="ShowResultFrameCheckBox" Content="显示匹配外框和中心" IsChecked="True" Margin="4" Checked="OverlayOptionChanged" Unchecked="OverlayOptionChanged" />
                                    <TextBlock x:Name="TemplateStatusText" Text="模板：未训练" TextWrapping="Wrap" Margin="4,6,4,0" />
                                    <TextBlock x:Name="MatchResultText" Text="结果：--" TextWrapping="Wrap" Margin="4,6,4,0" />
                                    <TextBlock x:Name="LastMessageText" Text="最新外发结果：--" TextWrapping="Wrap" Margin="4,6,4,0" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="通讯">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="TCP 通讯">
                                <StackPanel>
                                    <UniformGrid Columns="2">
                                        <RadioButton x:Name="TcpClientModeRadio" Content="TCP客户端" IsChecked="True" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                        <RadioButton x:Name="TcpServerModeRadio" Content="TCP服务端" HorizontalContentAlignment="Center" Checked="TcpModeChanged" />
                                    </UniformGrid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="92" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="TcpIpLabel" Text="远端IP" VerticalAlignment="Center" />
                                        <TextBox x:Name="TcpIpTextBox" Grid.Column="1" Text="127.0.0.1" />
                                        <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" />
                                        <TextBox x:Name="TcpPortTextBox" Grid.Column="3" Text="9000" />
                                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="4">
                                            <Button x:Name="TcpConnectButton" Content="连接" Click="TcpConnectButton_Click" />
                                            <Button x:Name="TcpDisconnectButton" Content="断开" Click="TcpDisconnectButton_Click" />
                                            <Button x:Name="TcpStartServerButton" Content="启动监听" Click="TcpStartServerButton_Click" />
                                            <Button x:Name="TcpStopServerButton" Content="停止监听" Click="TcpStopServerButton_Click" />
                                        </WrapPanel>
                                    </Grid>
                                    <WrapPanel>
                                        <TextBlock Text="编码" VerticalAlignment="Center" Margin="4" />
                                        <ComboBox x:Name="TcpEncodingCombo" Width="100" SelectedIndex="0">
                                            <ComboBoxItem Content="UTF-8" />
                                            <ComboBoxItem Content="ASCII" />
                                            <ComboBoxItem Content="GBK" />
                                        </ComboBox>
                                        <CheckBox x:Name="TcpAppendNewLineCheckBox" Content="追加换行" IsChecked="True" VerticalAlignment="Center" Margin="8,4" />
                                        <CheckBox x:Name="AutoSendMatchResultCheckBox" Content="自动发送结果" IsChecked="True" VerticalAlignment="Center" Margin="8,4" />
                                    </WrapPanel>
                                    <TextBlock x:Name="TcpStatusText" Text="未连接，发送不可用" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="手动发送">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox x:Name="TcpSendTextBox" Text="Hello" AcceptsReturn="True" Height="70" VerticalScrollBarVisibility="Auto" />
                                    <Button x:Name="TcpSendButton" Grid.Column="1" Content="发送文本" FontWeight="Bold" Click="TcpSendButton_Click" />
                                    <Button x:Name="SendLastMatchButton" Grid.Row="1" Grid.ColumnSpan="2" Content="发送最新检测结果" FontWeight="Bold" Click="SendLastMatchButton_Click" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="配方/诊断">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <GroupBox Header="当前配方">
                                <StackPanel>
                                    <TextBox x:Name="RecipeNameEditTextBox" Text="DefaultRecipe" />
                                    <TextBlock x:Name="RecipePathText" Text="路径：--" TextWrapping="Wrap" Foreground="#475569" Margin="4" />
                                    <WrapPanel>
                                        <Button Content="打开配方目录" Click="OpenRecipeDirectoryButton_Click" />
                                        <Button Content="打开日志目录" Click="OpenLogDirectoryButton_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="启动自检">
                                <DataGrid x:Name="DiagnosticsDataGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Height="230">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="项目" Binding="{Binding Name}" Width="120" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60" />
                                        <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#CBD5E1" />

        <TabControl Grid.Row="3" x:Name="BottomTabs" Margin="10,0,10,6">
            <TabItem Header="结果记录">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="4">
                        <Button x:Name="ReviewResultButton" Content="回看结果" Click="ReviewResultButton_Click" />
                        <Button x:Name="ExportCsvButton" Content="导出CSV" Click="ExportCsvButton_Click" />
                        <Button x:Name="ExportXlsxButton" Content="导出XLSX" Click="ExportXlsxButton_Click" />
                        <Button x:Name="ClearResultsButton" Content="清空记录" Click="ClearResultsButton_Click" />
                    </WrapPanel>
                    <DataGrid x:Name="ResultsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="48" />
                            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="100" />
                            <DataGridTextColumn Header="类型" Binding="{Binding InspectionType}" Width="120" />
                            <DataGridTextColumn Header="判定" Binding="{Binding ResultCode}" Width="70" />
                            <DataGridTextColumn Header="分数" Binding="{Binding Score, StringFormat=F3}" Width="70" />
                            <DataGridTextColumn Header="ROI" Binding="{Binding RoiType}" Width="80" />
                            <DataGridTextColumn Header="图像" Binding="{Binding ImageSource}" Width="220" />
                            <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="运行日志">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="4">
                        <Button x:Name="ClearLogButton" Content="清空日志" Click="ClearLogButton_Click" />
                        <Button x:Name="OpenLogDirectoryButton2" Content="打开日志目录" Click="OpenLogDirectoryButton_Click" />
                    </WrapPanel>
                    <TextBox x:Name="BottomLogTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="报警">
                <TextBox x:Name="AlarmTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </TabItem>
            <TabItem Header="通讯记录">
                <TextBox x:Name="TcpHistoryTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="4" Background="#FFFFFF" BorderBrush="#D6DCE5" BorderThickness="0,1,0,0">
            <StatusBarItem><TextBlock x:Name="ModeStatusText" Text="模式：手动调试" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="ImageStatusText" Text="图像：--" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="ZoomStatusText" Text="缩放：--" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="MouseStatusText" Text="坐标：--" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="RoiStatusBarText" Text="ROI：未设置" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="TemplateStatusBarText" Text="模板：未训练" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="TcpStatusBarText" Text="TCP：未连接" /></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
