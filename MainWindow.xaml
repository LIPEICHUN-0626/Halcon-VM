                            </StackPanel>

                            <StackPanel Visibility="Collapsed">
                                <CheckBox x:Name="EnableShapeToolCheckBox" /><CheckBox x:Name="EnableBlobToolCheckBox" /><CheckBox x:Name="EnableGrayToolCheckBox" /><CheckBox x:Name="EnableEdgeToolCheckBox" /><CheckBox x:Name="EnableHDevToolCheckBox" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="IoTab" Header="I/O" ToolTip="输入/输出">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <Border Background="#263449" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="IoToolTitleText" Text="未选择流程工具" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock x:Name="IoConnectionStatusText" Text="请在流程区选择工具实例。" Foreground="#C4B5FD" TextWrapping="Wrap" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <Button x:Name="IoOpenParametersButton" Content="参数" Click="IoOpenParametersButton_Click" />
                                <Button x:Name="IoRunCurrentButton" Content="运行当前" FontWeight="SemiBold" Click="IoRunCurrentButton_Click" />
                                <Button Content="刷新值" Click="IoRefreshButton_Click" />
                            </UniformGrid>

                            <GroupBox Header="输入端口 IN">
                                <ItemsControl x:Name="InputPortsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PortCard" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border x:Name="PortBadge" Width="30" Height="30" CornerRadius="15" Background="#FEE2E2" VerticalAlignment="Top">
                                                        <TextBlock Text="IN" FontSize="9" FontWeight="Bold" Foreground="#B91C1C" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontWeight="SemiBold"><Run Text="{Binding DisplayName}" /><Run Text="  (" /><Run Text="{Binding PortName}" /><Run Text=")" /></TextBlock>
                                                        <TextBlock Text="{Binding Source, StringFormat=来源：{0}}" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding CurrentValue, StringFormat=当前：{0}}" FontSize="10" Foreground="#334155" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border Background="#EDE9FE" CornerRadius="8" Padding="6,2"><TextBlock Text="{Binding DataType}" FontSize="9" Foreground="#6D28D9" /></Border>
                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="#B45309" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter TargetName="PortCard" Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter TargetName="PortBadge" Property="Background" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="输出端口 OUT">
                                <ItemsControl x:Name="OutputPortsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PortCard" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Padding="7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                    <Border x:Name="PortBadge" Width="30" Height="30" CornerRadius="15" Background="#E0E7FF" VerticalAlignment="Top">
                                                        <TextBlock Text="OUT" FontSize="8" FontWeight="Bold" Foreground="#4338CA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontWeight="SemiBold"><Run Text="{Binding DisplayName}" /><Run Text="  (" /><Run Text="{Binding PortName}" /><Run Text=")" /></TextBlock>
                                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding CurrentValue, StringFormat=当前：{0}}" FontSize="10" Foreground="#334155" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <Border Background="#EDE9FE" CornerRadius="8" Padding="6,2"><TextBlock Text="{Binding DataType}" FontSize="9" Foreground="#6D28D9" /></Border>
                                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="#475569" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter TargetName="PortCard" Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter TargetName="PortBadge" Property="Background" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="本次运行摘要">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock Text="输入" /><TextBlock x:Name="InspectorInputSummaryText" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1" Text="输出" /><TextBlock x:Name="InspectorOutputSummaryText" Grid.Row="1" Grid.Column="1" Text="--" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="2" Text="错误" /><TextBlock x:Name="InspectorErrorText" Grid.Row="2" Grid.Column="1" Text="--" TextWrapping="Wrap" Foreground="#B91C1C" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="RoiTab" Header="图像/ROI">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="9">
                            <GroupBox Header="绘制与视图">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button x:Name="RectangleRoiButton" Content="矩形" Click="RectangleRoiButton_Click" />
                                        <Button x:Name="CircleRoiButton" Content="圆形" Click="CircleRoiButton_Click" />
                                        <Button x:Name="PolygonRoiButton" Content="多边形" Click="PolygonRoiButton_Click" />
                                        <Button x:Name="ConfirmRoiButton" Content="确认并新增" FontWeight="Bold" Click="ConfirmRoiButton_Click" />
                                        <Button Content="取消绘制" Click="CancelRoiDrawingButton_Click" />
                                        <Button x:Name="FitImageButton" Content="适应窗口" Click="FitImageButton_Click" />
