<Window x:Class="HalconWinFormsDemo.ToolConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模块配置" Width="940" Height="690" MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Background="#EEF2F7">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Border Background="#263449" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel><TextBlock x:Name="ModuleTitleText" Foreground="White" FontSize="19" FontWeight="SemiBold" /><TextBlock x:Name="ModuleTypeText" Foreground="#BFDBFE" Margin="0,3,0,0" /></StackPanel>
                <Border Grid.Column="1" Background="#0F766E" CornerRadius="12" Padding="12,5" VerticalAlignment="Center"><TextBlock x:Name="ModuleStateText" Foreground="White" FontWeight="Bold" /></Border>
            </Grid>
        </Border>
        <TabControl x:Name="ConfigurationTabs" Grid.Row="1" Margin="12">
            <TabItem Header="基本参数">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="16">
                    <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="实例名称" VerticalAlignment="Center" /><TextBox x:Name="InstanceNameTextBox" Grid.Column="1" MinHeight="28" /></Grid>
                    <StackPanel x:Name="ImageSourcePanel">
                        <GroupBox Header="本地图像源">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="88" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock Text="图像文件" VerticalAlignment="Center" />
                                <TextBox x:Name="LocalImagePathTextBox" Grid.Column="1" MinHeight="28" />
                                <Button Grid.Column="2" Content="选择图片" Click="BrowseLocalImageButton_Click" />
                                <TextBlock Grid.Row="1" Text="图像 SN" VerticalAlignment="Center" />
                                <TextBox x:Name="LocalImageSerialTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" MinHeight="28" ToolTip="可填写工件号、采集序号或调试图像标识" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                    <StackPanel x:Name="BlobPanel"><GroupBox Header="Blob 参数"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><TextBlock Text="灰度下限" VerticalAlignment="Center" /><TextBox x:Name="BlobMinTextBox" Grid.Column="1" /><TextBlock Grid.Column="2" Text="灰度上限" VerticalAlignment="Center" /><TextBox x:Name="BlobMaxTextBox" Grid.Column="3" /><TextBlock Grid.Row="1" Text="最小面积" VerticalAlignment="Center" /><TextBox x:Name="BlobAreaTextBox" Grid.Row="1" Grid.Column="1" /></Grid></GroupBox></StackPanel>
                    <StackPanel x:Name="GrayPanel"><GroupBox Header="灰度统计参数"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="判定下限" VerticalAlignment="Center" /><TextBox x:Name="GrayMinTextBox" Grid.Column="1" /><TextBlock Grid.Column="2" Text="判定上限" VerticalAlignment="Center" /><TextBox x:Name="GrayMaxTextBox" Grid.Column="3" /></Grid></GroupBox></StackPanel>
                    <StackPanel x:Name="EdgePanel"><GroupBox Header="边缘测量参数"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="边缘阈值" VerticalAlignment="Center" /><TextBox x:Name="EdgeThresholdTextBox" Grid.Column="1" /></Grid></GroupBox></StackPanel>
                    <StackPanel x:Name="NumericPanel"><GroupBox Header="数值判定参数"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><TextBlock Text="比较方式" VerticalAlignment="Center" /><ComboBox x:Name="NumericOperatorComboBox" Grid.Column="1" Grid.ColumnSpan="3" DisplayMemberPath="DisplayText" SelectedValuePath="Key" /><TextBlock Grid.Row="1" Text="下限/目标" VerticalAlignment="Center" /><TextBox x:Name="NumericLowerTextBox" Grid.Row="1" Grid.Column="1" /><TextBlock Grid.Row="1" Grid.Column="2" Text="上限" VerticalAlignment="Center" /><TextBox x:Name="NumericUpperTextBox" Grid.Row="1" Grid.Column="3" /><TextBlock Grid.Row="2" Text="相等容差" VerticalAlignment="Center" /><TextBox x:Name="NumericToleranceTextBox" Grid.Row="2" Grid.Column="1" /></Grid></GroupBox></StackPanel>
                    <Border x:Name="CompatibilityPanel" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="4" Padding="12"><TextBlock Text="此模块本轮使用兼容配置入口；完整参数仍从主窗口现有配置页进入。" TextWrapping="Wrap" /></Border>
                    <TextBlock x:Name="ValidationText" Foreground="#B91C1C" TextWrapping="Wrap" Margin="4,10,4,0" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="运行参数"><StackPanel Margin="18"><CheckBox x:Name="EnabledCheckBox" Content="启用此模块" /><TextBlock Text="本模块遵循流程级单次、连续、暂停/停止、超时和遇 NG 停止策略。" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="#475569" /></StackPanel></TabItem>
            <TabItem Header="输入">
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Border Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1" CornerRadius="4" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="类型化输入订阅" FontWeight="SemiBold" Foreground="#065F46" /><TextBlock x:Name="InputText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#334155" /></StackPanel>
                            <Button Grid.Column="1" Content="应用并查看 I/O" Padding="12,6" Foreground="#0F766E" FontWeight="SemiBold" Click="OpenIoWorkspaceButton_Click" />
                        </Grid>
                    </Border>
                    <ListBox x:Name="InputPortItemsControl" Grid.Row="1" Margin="0,10,0,0"
                             BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Background="White" Padding="10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="190" /></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                <WrapPanel Margin="0,4,0,0"><Border Background="#DBEAFE" CornerRadius="8" Padding="7,2"><TextBlock Text="{Binding DataType}" Foreground="#1D4ED8" FontSize="10" /></Border><TextBlock Text="{Binding OptionalText}" Foreground="#64748B" FontSize="10" Margin="8,2,0,0" /></WrapPanel>
                                                <TextBlock Text="{Binding PortName}" Foreground="#94A3B8" FontFamily="Consolas" FontSize="10" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="10,0">
                                                <TextBlock Text="输入来源" Foreground="#64748B" FontSize="10" />
                                                <ComboBox ItemsSource="{Binding SourceOptions}" DisplayMemberPath="DisplayText" SelectedValuePath="Key" SelectedValue="{Binding SelectedSourceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="InputSourceComboBox_SelectionChanged" MinHeight="29" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="当前值 / 状态" Foreground="#64748B" FontSize="10" />
                                                <TextBlock Text="{Binding CurrentValue}" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding StatusText}" Foreground="#0F766E" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                    </ListBox>
                    <DockPanel Grid.Row="2" Margin="0,4,0,0">
                        <Button DockPanel.Dock="Right" Content="全部恢复默认输入" Padding="12,5" Click="ResetInputSourcesButton_Click" />
                        <TextBlock Text="只列出当前工具之前且数据类型匹配的输出；本轮不建立伪自由连线。" Foreground="#64748B" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="ROI / 模板">
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Border Background="#E0F2FE" BorderBrush="#7DD3FC" BorderThickness="1" CornerRadius="4" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ROI 绑定工作台" FontWeight="SemiBold" Foreground="#0C4A6E" />
                                <TextBlock x:Name="RoiText" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#334155" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="应用并返回图像区" Padding="12,6" Foreground="#0F766E" FontWeight="SemiBold" Click="OpenRoiWorkspaceButton_Click" />
                        </Grid>
                    </Border>
                    <StackPanel x:Name="RoiWorkspacePanel" Grid.Row="1" Margin="0,10,0,0">
                        <Grid x:Name="RoiModePanel" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="118" /><ColumnDefinition Width="280" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Text="多 ROI 执行模式" VerticalAlignment="Center" />
                            <ComboBox x:Name="RoiExecutionModeComboBox" Grid.Column="1" DisplayMemberPath="DisplayText" SelectedValuePath="Key" MinHeight="28" />
                            <TextBlock Grid.Column="2" Margin="12,0,0,0" Text="旧配方默认合并；逐 ROI 会为每个已启用绑定区生成独立判定。" Foreground="#64748B" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                        <DockPanel Margin="0,0,0,7">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="全选" MinWidth="66" Click="SelectAllRoiButton_Click" />
                                <Button Content="清空" MinWidth="66" Click="ClearRoiBindingsButton_Click" />
                            </StackPanel>
                            <TextBlock Text="绑定当前模块参与运行的 ROI 图层" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </DockPanel>
                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Background="White" MaxHeight="285">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="RoiBindingItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="8,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="32" /><ColumnDefinition Width="78" /><ColumnDefinition Width="140" /><ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="125" /></Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsBound}" VerticalAlignment="Center" Margin="2,0,10,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding SequenceText}" Foreground="#64748B" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding RoiIdText}" ToolTip="{Binding RoiId}" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Consolas" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="4" Text="{Binding ShapeText}" Foreground="#0369A1" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="5" Text="{Binding GeometryText}" Foreground="#64748B" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="6" Text="{Binding StateText}" Foreground="#0F766E" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <TextBlock x:Name="EmptyRoiText" Text="当前工程尚无 ROI；可直接返回图像区绘制。" Foreground="#B45309" Margin="2,7,0,0" Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock x:Name="RoiUnsupportedText" Grid.Row="1" Text="该模块没有 ROI 输入。" Foreground="#64748B" Margin="2,12,0,0" Visibility="Collapsed" />
                    <Border x:Name="RoiDrawPanel" Grid.Row="2" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,10,0,0">
                        <DockPanel>
                            <TextBlock Text="绘制后会自动绑定到当前模块：" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <WrapPanel>
                                <Button Content="矩形 ROI" Tag="RectangleRoi" Click="DrawRoiButton_Click" />
                                <Button Content="圆形 ROI" Tag="CircleRoi" Click="DrawRoiButton_Click" />
                                <Button Content="多边形 ROI" Tag="PolygonRoi" Click="DrawRoiButton_Click" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="结果显示">
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="最近一次结果" FontWeight="SemiBold" />
                    <StackPanel Grid.Row="1"><TextBlock x:Name="ResultText" Margin="0,8,0,0" TextWrapping="Wrap" /><TextBlock x:Name="ErrorText" Margin="0,8,0,0" Foreground="#B91C1C" TextWrapping="Wrap" /></StackPanel>
                    <GroupBox Grid.Row="2" Header="逐 ROI 结果" Margin="0,12,0,0">
                        <DataGrid x:Name="RoiResultsDataGrid" ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding RoiName}" Width="120" />
                                <DataGridTextColumn Header="形状" Binding="{Binding ShapeText}" Width="90" />
                                <DataGridTextColumn Header="判定" Binding="{Binding ResultCode}" Width="65" />
                                <DataGridTextColumn Header="数值" Binding="{Binding ValueText}" Width="130" />
                                <DataGridTextColumn Header="耗时" Binding="{Binding ElapsedText}" Width="75" />
                                <DataGridTextColumn Header="说明" Binding="{Binding DisplayMessage}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="帮助"><StackPanel Margin="18"><TextBlock x:Name="HelpText" TextWrapping="Wrap" /><TextBlock Text="参数应用到当前实例，不会修改同类型的其他模块。取消不会写入尚未应用的草稿。" Margin="0,14,0,0" Foreground="#0F766E" TextWrapping="Wrap" /></StackPanel></TabItem>
        </TabControl>
        <Border Grid.Row="2" Background="White" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="10">
            <DockPanel><Button x:Name="TrialRunButton" DockPanel.Dock="Left" Content="▶ 试运行" MinWidth="100" Click="TrialRunButton_Click" /><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="应用" MinWidth="82" Click="ApplyButton_Click" /><Button Content="确定" MinWidth="82" IsDefault="True" Click="OkButton_Click" /><Button Content="取消" MinWidth="82" IsCancel="True" /></StackPanel><TextBlock x:Name="FooterText" VerticalAlignment="Center" Foreground="#64748B" Margin="12,0" /></DockPanel>
        </Border>
    </Grid>
</Window>
